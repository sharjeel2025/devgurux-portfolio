    <!-- JAVASCRIPT ANIMATIONS & INTERACTIVE LOGIC -->
    <script>
        // DOM ELEMENTS NAVIGATION
        const mobileToggle = document.getElementById('mobile-toggle');
        const mobileDrawer = document.getElementById('mobile-drawer');
        const preloader = document.getElementById('preloader');

        // Preloader transition completion
        window.addEventListener('load', () => {
            setTimeout(() => {
                preloader.classList.add('opacity-0');
                setTimeout(() => {
                    preloader.style.display = 'none';
                }, 1000);
            }, 1000);
        });

        // Mobile Drawer Controller
        mobileToggle.addEventListener('click', toggleDrawer);
        function toggleDrawer() {
            mobileDrawer.classList.toggle('hidden');
            const icon = mobileToggle.querySelector('i');
            if (mobileDrawer.classList.contains('hidden')) {
                icon.className = 'fa-solid fa-bars-staggered text-xl';
            } else {
                icon.className = 'fa-solid fa-xmark text-xl';
            }
        }

        // Close drawer on clicking options
        document.querySelectorAll('.drawer-link').forEach(link => {
            link.addEventListener('click', () => {
                mobileDrawer.classList.add('hidden');
                mobileToggle.querySelector('i').className = 'fa-solid fa-bars-staggered text-xl';
            });
        });

        // TOAST NOTIFICATIONS
        function showToast(message) {
            const toast = document.getElementById('custom-toast');
            const toastMsg = document.getElementById('toast-message');

            toastMsg.innerText = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // ==========================================
        // MENU ESTIMATOR CALCULATIONS
        // ==========================================
        let estimatorState = {
            tierPrice: 195,
            tierName: "3 Courses prelude",
            addons: []
        };

        function selectMenuTier(tierNum, price) {
            estimatorState.tierPrice = price;
            estimatorState.tierName = `${tierNum} Courses symphony`;

            // Style active tier UI card
            document.querySelectorAll('.menu-tier-card').forEach(card => {
                if (card.id === `tier-${tierNum}`) {
                    card.className = 'menu-tier-card group p-5 bg-charcoal border border-goldChampagne/60 rounded cursor-pointer transition duration-300';
                } else {
                    card.className = 'menu-tier-card group p-5 bg-charcoal border border-white/5 hover:border-goldChampagne/30 rounded cursor-pointer transition duration-300';
                }
            });

            renderMenuStatement();
        }

        function toggleMenuAddon(name, price, elementId) {
            const index = estimatorState.addons.findIndex(item => item.name === name);
            const card = document.getElementById(elementId);
            const statusLabel = document.getElementById(`${elementId}-status`);

            if (index > -1) {
                estimatorState.addons.splice(index, 1);
                card.classList.remove('border-goldChampagne');
                statusLabel.innerText = 'Add';
                statusLabel.classList.remove('text-goldChampagne');
                statusLabel.classList.add('text-gray-500');
                showToast(`Removed accessory pairing: ${name}`);
            } else {
                estimatorState.addons.push({ name, price });
                card.classList.add('border-goldChampagne');
                statusLabel.innerText = 'Applied';
                statusLabel.classList.remove('text-gray-500');
                statusLabel.classList.add('text-goldChampagne');
                showToast(`Applied accessory pairing: ${name}`);
            }

            renderMenuStatement();
        }

        function renderMenuStatement() {
            const appliedContainer = document.getElementById('rec-applied-addons-box');
            const addonsItems = document.getElementById('rec-addons-items');

            document.getElementById('rec-tier').innerText = estimatorState.tierName;
            document.getElementById('rec-base-cost').innerText = `$${estimatorState.tierPrice} / guest`;

            if (estimatorState.addons.length === 0) {
                appliedContainer.classList.add('hidden');
            } else {
                appliedContainer.classList.remove('hidden');
                addonsItems.innerHTML = '';
                estimatorState.addons.forEach(add => {
                    const div = document.createElement('div');
                    div.className = 'flex justify-between text-xs text-gray-300';
                    div.innerHTML = `<span>${add.name}</span><span class="text-goldChampagne font-bold">+$${add.price}</span>`;
                    addonsItems.appendChild(div);
                });
            }

            let addonsTotal = estimatorState.addons.reduce((sum, item) => sum + item.price, 0);
            let finalEstimate = estimatorState.tierPrice + addonsTotal;

            document.getElementById('rec-total-cost').innerText = `$${finalEstimate} / guest`;
        }

        function bookWithTastingDetails() {
            openQuoteModal();
            selectWizardSalon('Main Salon');
            document.getElementById('wiz-guests').value = 2;
            goToWizardStep(2);
        }

        // ==========================================
        // CONVERSATIONAL RESERVATION PORTAL WIZARD STATE
        // ==========================================
        let wizardState = {
            step: 1,
            salon: 'Main Salon',
            guests: 2,
            basePrice: 295,
            courses: '5 Symphony Tier',
            addWine: false,
            addCaviar: false
        };

        function openQuoteModal() {
            document.getElementById('quote-modal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            goToWizardStep(1);
        }

        function closeQuoteModal() {
            document.getElementById('quote-modal').classList.add('hidden');
            document.body.style.overflow = 'auto';

            document.getElementById('step-success').classList.add('hidden');
            document.getElementById('step-sector').classList.remove('hidden');
            document.getElementById('step-materials').classList.add('hidden');
            document.getElementById('step-verify').classList.add('hidden');
        }

        function selectWizardSalon(name) {
            wizardState.salon = name;
            const radios = document.getElementsByName('wiz-srv');
            radios.forEach(r => {
                if (r.value === name) r.checked = true;
            });
        }

        function goToWizardStep(step) {
            wizardState.step = step;

            const stages = {
                1: document.getElementById('wiz-s1'),
                2: document.getElementById('wiz-s2'),
                3: document.getElementById('wiz-s3')
            };

            for (let s in stages) {
                if (s == step) {
                    stages[s].className = 'text-goldChampagne font-bold';
                } else {
                    stages[s].className = 'text-gray-600';
                }
            }

            document.getElementById('step-sector').classList.add('hidden');
            document.getElementById('step-materials').classList.add('hidden');
            document.getElementById('step-verify').classList.add('hidden');

            if (step === 1) {
                document.getElementById('step-sector').classList.remove('hidden');
            } else if (step === 2) {
                document.getElementById('step-materials').classList.remove('hidden');
            } else if (step === 3) {
                document.getElementById('step-verify').classList.remove('hidden');

                // Capture inputs
                wizardState.guests = parseInt(document.getElementById('wiz-guests').value) || 2;
                
                const courseSelect = document.getElementById('wiz-course-pref');
                const courseOption = courseSelect.options[courseSelect.selectedIndex];
                wizardState.courses = `${courseOption.value} Symphony Tier`;
                wizardState.basePrice = parseFloat(courseOption.getAttribute('data-price'));

                wizardState.addWine = document.getElementById('wiz-add-wine').checked;
                wizardState.addCaviar = document.getElementById('wiz-add-caviar').checked;

                // Total estimation formulation inside summary
                let baseCosts = wizardState.basePrice * wizardState.guests;
                let wineCosts = wizardState.addWine ? (125 * wizardState.guests) : 0;
                let caviarCosts = wizardState.addCaviar ? (95 * wizardState.guests) : 0;
                let totalWizardCosts = baseCosts + wineCosts + caviarCosts;

                document.getElementById('sum-salon').innerText = wizardState.salon;
                document.getElementById('sum-guests').innerText = `${wizardState.guests} Guests`;
                document.getElementById('sum-course').innerText = wizardState.courses;
                document.getElementById('sum-total').innerText = `$${totalWizardCosts.toLocaleString()}`;
            }
        }

        function finalizeWizardBooking() {
            const name = document.getElementById('wiz-client-name').value;
            const phone = document.getElementById('wiz-client-phone').value;
            const email = document.getElementById('wiz-client-email').value;

            if (!name || !phone || !email) {
                showToast("Please authenticate identity credentials.");
                return;
            }

            document.getElementById('step-verify').classList.add('hidden');
            document.getElementById('step-success').classList.remove('hidden');
        }

        // ==========================================
        // THREE.JS 4K CINEMATIC FOOD PRESENTATION SCENE
        // ==========================================
        let scene, camera, renderer, diningGroup, seasonalFoilParticles;
        let ambientLight, directLight, warmSpotLight, coolKeyLight;

        let isDragging = false;
        let previousMousePosition = { x: 0, y: 0 };
        let dragRotationOffset = { x: 0, y: 0 };
        let targetDragRotationOffset = { x: 0, y: 0 };

        let scrollY = 0;
        let lerpScrollY = 0;

        window.addEventListener('scroll', () => {
            scrollY = window.scrollY;
        });

        function setupInteractiveDrag() {
            const zone = document.getElementById('hero-3d-interactive-zone');
            if (!zone) return;

            zone.addEventListener('mousedown', (e) => {
                isDragging = true;
                previousMousePosition = { x: e.clientX, y: e.clientY };
            });

            window.addEventListener('mouseup', () => {
                isDragging = false;
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                const deltaMove = {
                    x: e.clientX - previousMousePosition.x,
                    y: e.clientY - previousMousePosition.y
                };

                targetDragRotationOffset.y += deltaMove.x * 0.007;
                targetDragRotationOffset.x += deltaMove.y * 0.007;

                previousMousePosition = { x: e.clientX, y: e.clientY };
            });

            zone.addEventListener('touchstart', (e) => {
                isDragging = true;
                const touch = e.touches[0];
                previousMousePosition = { x: touch.clientX, y: touch.clientY };
            }, { passive: true });

            window.addEventListener('touchmove', (e) => {
                if (!isDragging) return;
                const touch = e.touches[0];
                const deltaMove = {
                    x: touch.clientX - previousMousePosition.x,
                    y: touch.clientY - previousMousePosition.y
                };

                targetDragRotationOffset.y += deltaMove.x * 0.007;
                targetDragRotationOffset.x += deltaMove.y * 0.007;

                previousMousePosition = { x: touch.clientX, y: touch.clientY };
            }, { passive: true });

            window.addEventListener('touchend', () => {
                isDragging = false;
            });
        }

        function buildCinematicThreeJS() {
            const viewport = document.getElementById('canvas-viewport');
            const width = window.innerWidth;
            const height = window.innerHeight;

            scene = new THREE.Scene();

            camera = new THREE.PerspectiveCamera(40, width / height, 0.1, 100);
            camera.position.set(0, 5.0, 16.0);

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(width, height);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            viewport.appendChild(renderer.domElement);

            // Parent culinary layout group
            diningGroup = new THREE.Group();

            // 1. BLACK LUXURY MARBLE PLATE BASE
            const plateGeo = new THREE.CylinderGeometry(4.0, 4.0, 0.3, 40);
            const marbleMat = new THREE.MeshStandardMaterial({
                color: 0x111111,
                roughness: 0.15,
                metalness: 0.8
            });
            const plate = new THREE.Mesh(plateGeo, marbleMat);
            plate.position.y = -2.0;
            diningGroup.add(plate);

            // 2. LUXURY GOLD PLATE DECORATIVE RIM
            const rimGeo = new THREE.TorusGeometry(4.0, 0.08, 12, 48);
            const goldMat = new THREE.MeshStandardMaterial({
                color: 0xD4AF37,
                roughness: 0.1,
                metalness: 0.95
            });
            const rim = new THREE.Mesh(rimGeo, goldMat);
            rim.rotation.x = Math.PI / 2;
            rim.position.y = -1.85;
            diningGroup.add(rim);

            // 3. SECURE CHAMBER COUPLING COVER (CLOCHE / DOME)
            const clocheGroup = new THREE.Group();
            clocheGroup.position.y = -1.85;

            // Cloche main body dome
            const domeGeo = new THREE.SphereGeometry(3.9, 32, 16, 0, Math.PI * 2, 0, Math.PI / 2);
            const domeMat = new THREE.MeshPhysicalMaterial({
                color: 0xD4AF37,
                roughness: 0.2,
                metalness: 0.9,
                clearcoat: 1.0,
                clearcoatRoughness: 0.1,
                side: THREE.DoubleSide
            });
            const clocheDome = new THREE.Mesh(domeGeo, domeMat);
            clocheGroup.add(clocheDome);

            // Cloche handle ring at the top
            const handleGeo = new THREE.TorusGeometry(0.35, 0.08, 8, 24);
            const handle = new THREE.Mesh(handleGeo, goldMat);
            handle.position.y = 3.9;
            clocheGroup.add(handle);

            diningGroup.add(clocheGroup);

            // 4. ARCHITECTURAL GEOMETRIC DISH ASSEMBLY (Molecular gastronomy representation)
            const dishGroup = new THREE.Group();
            dishGroup.position.y = -1.5;

            // Concentric crystalline spun sugar rings
            const ringGeo = new THREE.TorusGeometry(1.6, 0.05, 8, 48);
            const glassSugarMat = new THREE.MeshPhysicalMaterial({
                color: 0xD4AF37,
                transmission: 0.9,
                opacity: 0.8,
                roughness: 0.1,
                transparent: true
            });
            const ring1 = new THREE.Mesh(ringGeo, glassSugarMat);
            ring1.rotation.x = Math.PI / 2;
            dishGroup.add(ring1);

            const ring2 = ring1.clone();
            ring2.scale.set(0.7, 0.7, 0.7);
            ring2.position.y = 0.4;
            ring2.rotation.y = Math.PI / 6;
            dishGroup.add(ring2);

            // Central golden organic ribbon spiral (Mathematical helix curves)
            const spiralGroup = new THREE.Group();
            const sphereGeo = new THREE.SphereGeometry(0.08, 8, 8);
            for (let i = 0; i < 40; i++) {
                const angle = i * 0.4;
                const r = 0.8 - (i * 0.015);
                const sp = new THREE.Mesh(sphereGeo, goldMat);
                sp.position.set(Math.cos(angle) * r, i * 0.05, Math.sin(angle) * r);
                spiralGroup.add(sp);
            }
            dishGroup.add(spiralGroup);

            // Molecular gastronomic spheres / caviar droplets
            const caviarGeo = new THREE.SphereGeometry(0.12, 12, 12);
            const caviarMat = new THREE.MeshPhysicalMaterial({
                color: 0x8C6239,
                roughness: 0.05,
                metalness: 0.1,
                transmission: 0.8,
                transparent: true
            });
            for (let i = 0; i < 12; i++) {
                const droplet = new THREE.Mesh(caviarGeo, caviarMat);
                const angle = (i / 12) * Math.PI * 2;
                droplet.position.set(Math.cos(angle) * 1.1, 0.08, Math.sin(angle) * 1.1);
                dishGroup.add(droplet);
            }

            diningGroup.add(dishGroup);
            scene.add(diningGroup);

            // 5. GOLD FLAKE AND SENSORY DRIFT PARTICLES
            const particlesCount = 220;
            const particleGeo = new THREE.BufferGeometry();
            const positionsArray = new Float32Array(particlesCount * 3);

            for (let i = 0; i < particlesCount * 3; i += 3) {
                positionsArray[i] = (Math.random() - 0.5) * 20;     // X drift
                positionsArray[i + 1] = (Math.random() - 0.5) * 15; // Y drift
                positionsArray[i + 2] = (Math.random() - 0.5) * 20; // Z drift
            }

            particleGeo.setAttribute('position', new THREE.BufferAttribute(positionsArray, 3));

            const particleMaterial = new THREE.PointsMaterial({
                size: 0.06,
                color: 0xD4AF37, // Warm golden flake embers
                transparent: true,
                opacity: 0.55,
                blending: THREE.AdditiveBlending
            });

            seasonalFoilParticles = new THREE.Points(particleGeo, particleMaterial);
            scene.add(seasonalFoilParticles);

            // STUDIO LIGHTING SETUP
            ambientLight = new THREE.AmbientLight(0xffffff, 0.25);
            scene.add(ambientLight);

            // Direct overhead spotlight
            directLight = new THREE.DirectionalLight(0xffffff, 2.0);
            directLight.position.set(5, 15, 5);
            scene.add(directLight);

            // High intensity golden accent spotlight
            warmSpotLight = new THREE.SpotLight(0xD4AF37, 5.0, 30, Math.PI / 4, 0.5, 1);
            warmSpotLight.position.set(-5, 10, 5);
            scene.add(warmSpotLight);

            // Soft luxury room key light
            coolKeyLight = new THREE.DirectionalLight(0xA3704C, 1.5);
            coolKeyLight.position.set(5, -5, -5);
            scene.add(coolKeyLight);

            window.addEventListener('resize', onWindowResize);
            applyResponsiveFit();
            setupInteractiveDrag();

            // Begin rendering frames
            animateCinematic();
        }

        // SCALING CORRECTIONS FOR ALL VIEWPORTS
        function applyResponsiveFit() {
            if (!diningGroup) return;
            const width = window.innerWidth;
            
            if (width < 640) {
                diningGroup.scale.set(0.65, 0.65, 0.65);
            } else if (width < 1024) {
                diningGroup.scale.set(0.85, 0.85, 0.85);
            } else {
                diningGroup.scale.set(1.15, 1.15, 1.15);
            }
        }

        function onWindowResize() {
            const width = window.innerWidth;
            const height = window.innerHeight;

            camera.aspect = width / height;
            camera.updateProjectionMatrix();

            renderer.setSize(width, height);
            applyResponsiveFit();
        }

        // CINEMATIC KINETIC RENDER LOOP
        let animationTimer = 0;
        function animateCinematic() {
            requestAnimationFrame(animateCinematic);
            animationTimer += 0.01;

            // Interpolated Scroll Physics (Lerping)
            lerpScrollY += (scrollY - lerpScrollY) * 0.06;

            const docHeight = document.documentElement.scrollHeight - window.innerHeight || 1;
            const scrollFraction = Math.min(lerpScrollY / docHeight, 1.0);

            // DRAG TENSION DECAY CONTROL
            if (!isDragging) {
                targetDragRotationOffset.x *= 0.95;
                targetDragRotationOffset.y *= 0.95;
            }

            dragRotationOffset.x += (targetDragRotationOffset.x - dragRotationOffset.x) * 0.15;
            dragRotationOffset.y += (targetDragRotationOffset.y - dragRotationOffset.y) * 0.15;

            // 1. SCROLL-TIED STRUCTURAL CLOCHE DOME REVEAL
            if (diningGroup) {
                const cloche = diningGroup.children[2]; // Index of cloche group in parent layout
                const molecularDish = diningGroup.children[3]; // Index of culinary molecular dish

                // Cloche raises along Y-axis as scroll begins
                if (scrollFraction < 0.3) {
                    cloche.position.y = -1.85 + (scrollFraction * 3.3 * 8.0);
                    cloche.rotation.y = scrollFraction * Math.PI;
                    cloche.visible = true;
                } else {
                    // Fully lift cloche out of frame
                    cloche.position.y = 8.0;
                    cloche.visible = false;
                }

                // Spun sugar glass rings counter-rotate as user moves down
                molecularDish.children[0].rotation.z = animationTimer * 0.2 + (scrollFraction * Math.PI);
                molecularDish.children[1].rotation.z = -animationTimer * 0.3 - (scrollFraction * Math.PI * 1.5);
            }

            // 2. CAMERA SEAMLESS STORY SCENE POSITIONS
            const isMobile = window.innerWidth < 768;

            if (diningGroup) {
                if (isMobile) {
                    diningGroup.position.x = 0;
                    diningGroup.position.y = -0.5 + (scrollFraction * 1.5);
                    diningGroup.position.z = -1.0;

                    diningGroup.rotation.x = dragRotationOffset.x;
                    diningGroup.rotation.y = dragRotationOffset.y + (scrollFraction * Math.PI * 1.5);
                } else {
                    // Desktop trajectory: Middle right on hero, shifts and zooms sequentially on sections
                    diningGroup.position.x = 2.4 - (scrollFraction * 5.0);
                    diningGroup.position.y = -0.3 + (scrollFraction * 1.0);
                    diningGroup.position.z = 0.0 + (scrollFraction * 1.5);

                    diningGroup.rotation.x = dragRotationOffset.x + (Math.sin(animationTimer * 0.25) * 0.05);
                    diningGroup.rotation.y = dragRotationOffset.y + (animationTimer * 0.05 + (scrollFraction * Math.PI * 1.8));
                }
            }

            // 3. FLAKE EMBER PARTICLES DRIFT MOTION
            if (seasonalFoilParticles) {
                const positions = seasonalFoilParticles.geometry.attributes.position.array;
                for (let i = 0; i < positions.length; i += 3) {
                    positions[i + 1] -= 0.015 + (scrollFraction * 0.04); // Particles fall
                    if (positions[i + 1] < -8) {
                        positions[i + 1] = 8; // Reset back to top
                    }
                }
                seasonalFoilParticles.geometry.attributes.position.needsUpdate = true;
            }

            renderer.render(scene, camera);
        }

        // Initialize 3D Engine on load
        window.onload = function () {
            buildCinematicThreeJS();
            selectMenuTier(3, 195); // Fire baseline calculations
        }
    </script>

