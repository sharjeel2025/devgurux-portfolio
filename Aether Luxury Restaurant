<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AETHER | Immersive Michelin Gastronomy & Sensory Atelier</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        obsidian: '#090A09',
                        charcoal: '#141614',
                        goldChampagne: '#D4AF37',
                        bronzeAura: '#A3704C',
                        platinumWarm: '#FAF9F6',
                    },
                    fontFamily: {
                        editorial: ['Playfair Display', 'serif'],
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Three.js Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #090A09;
            color: #FAF9F6;
            overflow-x: hidden;
        }
        .font-serif-luxury {
            font-family: 'Playfair Display', serif;
        }
        /* Custom scrollbar matching champagne theme */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #090A09;
        }
        ::-webkit-scrollbar-thumb {
            background: #D4AF37;
            border-radius: 3px;
        }
        /* Fixed full-screen interactive background viewport */
        #canvas-viewport {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 1; 
            pointer-events: none; /* Let HTML click actions pass through directly */
        }
        /* Glassmorphism utility card */
        .glass-luxury-panel {
            background: rgba(14, 16, 14, 0.72);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 175, 55, 0.08);
        }
        .gold-border-hover:hover {
            border-color: #D4AF37;
            box-shadow: 0 0 25px rgba(212, 175, 55, 0.15);
        }
    </style>
</head>
<body class="bg-obsidian text-platinumWarm selection:bg-goldChampagne selection:text-obsidian">

    <!-- PRELOADER -->
    <div id="preloader" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-obsidian transition-opacity duration-1000">
        <div class="text-center space-y-6">
            <div class="relative w-28 h-28 mx-auto flex items-center justify-center">
                <!-- Golden swirling orbital indicator -->
                <div class="absolute inset-0 rounded-full border-2 border-dashed border-goldChampagne/30 animate-spin duration-5000"></div>
                <!-- Core culinary geometric icon -->
                <div class="absolute inset-4 flex items-center justify-center text-goldChampagne text-3xl">
                    <i class="fa-solid fa-cookie-bite animate-pulse"></i>
                </div>
            </div>
            <div class="space-y-2">
                <h1 class="font-serif-luxury text-4xl font-light tracking-[0.3em] text-white">AETHER</h1>
                <p class="text-[10px] uppercase tracking-[0.5em] text-gray-500 font-semibold">Michelin Gastronomy Sanctuary</p>
            </div>
        </div>
    </div>

    <!-- IMMERSIVE 3D BACKGROUND ENGINE -->
    <div id="canvas-viewport"></div>

    <!-- NAVIGATION HEADER -->
    <header class="fixed top-0 left-0 w-full z-40 transition-all duration-300 bg-obsidian/40 backdrop-blur-md border-b border-white/5">
        <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
            <a href="#" class="font-serif-luxury text-2xl tracking-[0.2em] text-white hover:text-goldChampagne transition">
                AETHER<span class="text-goldChampagne font-normal">.</span>
            </a>
            
            <!-- Desktop Luxury Links -->
            <nav class="hidden lg:flex items-center space-x-12 text-[10px] uppercase tracking-widest font-bold text-gray-300">
                <a href="#hero" class="hover:text-white hover:underline decoration-goldChampagne decoration-2 underline-offset-8 transition">The Salon</a>
                <a href="#about" class="hover:text-white hover:underline decoration-goldChampagne decoration-2 underline-offset-8 transition">Concept</a>
                <a href="#menu" class="hover:text-white hover:underline decoration-goldChampagne decoration-2 underline-offset-8 transition">Menu Artistry</a>
                <a href="#chef" class="hover:text-white hover:underline decoration-goldChampagne decoration-2 underline-offset-8 transition">Chef</a>
                <a href="#reservation" class="hover:text-white hover:underline decoration-goldChampagne decoration-2 underline-offset-8 transition">Reservations</a>
            </nav>

            <!-- Call to Actions -->
            <div class="flex items-center space-x-6">
                <button onclick="openBookingModal()" class="px-6 py-3 border border-goldChampagne text-goldChampagne hover:bg-goldChampagne hover:text-obsidian text-[10px] uppercase tracking-widest font-bold transition-all duration-500 rounded hover:shadow-lg hover:shadow-goldChampagne/10">
                    Book Séance
                </button>
                <button id="mobile-toggle" class="lg:hidden text-white focus:outline-none p-2">
                    <i class="fa-solid fa-bars-staggered text-xl"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Drawer Menu -->
        <div id="mobile-drawer" class="hidden lg:hidden bg-obsidian border-t border-white/5 px-6 py-6 absolute top-full left-0 w-full flex flex-col space-y-4 text-[10px] uppercase tracking-widest font-bold text-gray-300">
            <a href="#hero" class="drawer-link py-2 border-b border-white/5 hover:text-goldChampagne transition">The Salon</a>
            <a href="#about" class="drawer-link py-2 border-b border-white/5 hover:text-goldChampagne transition">Concept</a>
            <a href="#menu" class="drawer-link py-2 border-b border-white/5 hover:text-goldChampagne transition">Menu Artistry</a>
            <a href="#chef" class="drawer-link py-2 border-b border-white/5 hover:text-goldChampagne transition">Chef</a>
            <a href="#reservation" class="drawer-link py-2 border-b border-white/5 hover:text-goldChampagne transition">Reservations</a>
            <button onclick="openBookingModal(); toggleDrawer();" class="w-full mt-4 py-3 bg-goldChampagne text-obsidian font-bold text-center uppercase tracking-widest hover:bg-white transition">
                Secure Reservation
            </button>
        </div>
    </header>

    <!-- MAIN INTERACTIVE PAGE CONTENT (SCROLL OVERLAY) -->
    <main class="relative z-10 bg-transparent">

        <!-- SCENE 1 & 2 HERO LANDING -->
        <section id="hero" class="min-h-screen flex items-center justify-start px-6 md:px-12 lg:px-24 py-16 relative">
            <div class="max-w-xl lg:max-w-2xl space-y-8 text-left relative z-20">
                <div class="inline-flex items-center space-x-3 px-3 py-1 border border-goldChampagne/30 rounded bg-goldChampagne/5 text-goldChampagne text-[10px] tracking-widest uppercase">
                    <span class="w-1.5 h-1.5 rounded-full bg-goldChampagne animate-ping"></span>
                    <span>Ranked No. 4 Global Gastronomy Atelier</span>
                </div>

                <h1 class="font-serif-luxury text-5xl sm:text-7xl lg:text-8xl font-light tracking-wide leading-none text-white">
                    Savor <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-goldChampagne via-bronzeAura to-amber-500 italic">Prestige.</span>
                </h1>

                <p class="text-gray-400 text-sm md:text-base max-w-xl leading-relaxed">
                    A multi-sensory culinary theater redefining the boundaries of physical texture, atomic heat, and botanical essence. Designed for extreme sensory transcendence.
                </p>

                <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-4 max-w-md">
                    <button onclick="openBookingModal()" class="px-8 py-4 bg-goldChampagne hover:bg-white text-obsidian font-bold text-center text-[10px] uppercase tracking-widest rounded transition duration-300">
                        Reserve Dinner Experience
                    </button>
                    <a href="#menu" class="px-8 py-4 border border-white/20 hover:border-goldChampagne text-center text-white hover:text-goldChampagne text-[10px] uppercase tracking-widest font-bold rounded transition duration-300 backdrop-blur-sm">
                        Explore Menu Artistry
                    </a>
                </div>

                <div class="flex items-center space-x-4 pt-8 text-[10px] text-gray-500 tracking-widest uppercase">
                    <i class="fa-solid fa-arrow-down-long text-goldChampagne animate-bounce"></i>
                    <span>Scroll to Lift the Golden Cloche & Plate the Art</span>
                </div>
            </div>

            <!-- Interactivity zone allowing drag inspection over the 3D canvas -->
            <div id="hero-3d-interactive-zone" class="absolute right-0 lg:right-12 xl:right-24 top-1/2 -translate-y-1/2 w-full lg:w-[45%] h-[400px] lg:h-[600px] z-30 pointer-events-auto cursor-grab active:cursor-grabbing">
                <div class="absolute bottom-4 right-4 bg-obsidian/85 backdrop-blur-md px-4 py-2 border border-goldChampagne/30 rounded text-[9px] tracking-widest uppercase text-goldChampagne font-bold pointer-events-none select-none flex items-center space-x-2">
                    <i class="fa-solid fa-arrows-spin animate-spin"></i>
                    <span>Drag / Swipe to Rotate Tasting plate</span>
                </div>
            </div>

            <!-- Visual ambient structural glow -->
            <div class="absolute left-10 bottom-1/4 w-[350px] h-[350px] bg-goldChampagne/5 rounded-full blur-[100px] pointer-events-none hidden lg:block"></div>
        </section>

        <!-- SCENE 3 ABOUT THE STORY -->
        <section id="about" class="py-24 px-6 md:px-12 max-w-7xl mx-auto relative z-20">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                
                <div class="lg:col-span-6 space-y-6">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-goldChampagne font-bold">The Creative Vision</span>
                    <h2 class="font-serif-luxury text-4xl md:text-5xl font-light text-white leading-tight">Decisive Harmony of Atomic Texture & Botanical Essence</h2>
                    <p class="text-gray-400 text-sm md:text-base leading-relaxed">
                        At AETHER, each course acts as an intellectual dialogue between Chef Marc de L'Étoile and Earth's rarest ecosystems. Utilizing state-of-the-art cold-vacuum chamber reduction, liquid carbon sculpting, and precise molecular atomizing, we elevate native botanical materials to visual fine art.
                    </p>
                    <p class="text-gray-400 text-sm leading-relaxed">
                        We purchase from exclusive biodynamic gardens spanning the volcanic terraces of Sicily, the deep ocean troughs of Hokkaido, and the ancient forests of Alsace to establish a dining ritual of incomparable truth.
                    </p>

                    <!-- Industry Credentials -->
                    <div class="grid grid-cols-3 gap-6 pt-6 border-t border-white/5 text-center lg:text-left">
                        <div>
                            <span class="font-serif-luxury text-3xl font-light text-white">★★★</span>
                            <span class="block text-[8px] uppercase tracking-wider text-gray-500 mt-1">Michelin Stars</span>
                        </div>
                        <div>
                            <span class="font-serif-luxury text-3xl font-light text-white">No. 4</span>
                            <span class="block text-[8px] uppercase tracking-wider text-gray-500 mt-1">World Rank</span>
                        </div>
                        <div>
                            <span class="font-serif-luxury text-3xl font-light text-white">100%</span>
                            <span class="block text-[8px] uppercase tracking-wider text-gray-500 mt-1">Biodynamic Source</span>
                        </div>
                    </div>
                </div>

                <!-- Culinary Masterpiece Showcase Card -->
                <div class="lg:col-span-6 relative group">
                    <div class="absolute -inset-1 bg-gradient-to-r from-goldChampagne/30 to-bronzeAura/20 rounded-lg blur opacity-75 group-hover:opacity-100 transition duration-1000"></div>
                    <div class="relative bg-charcoal border border-white/10 p-2 rounded-lg">
                        <img src="https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&q=80&w=800" alt="Symphony of Molecular Salmon" class="w-full h-[400px] object-cover rounded" onerror="this.src='https://placehold.co/800x600/141614/D4AF37?text=Gastronomy+Artistry+Assemblage'">
                    </div>
                </div>

            </div>
        </section>

        <!-- INTERACTIVE MENU TASTING FLIGHT PLANNER -->
        <section id="menu" class="py-24 px-6 md:px-12 bg-charcoal/40 border-y border-white/5 relative z-20">
            <div class="max-w-7xl mx-auto space-y-16">
                
                <div class="text-center space-y-4">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-goldChampagne font-bold">Curated Menus</span>
                    <h2 class="font-serif-luxury text-4xl md:text-5xl font-light text-white">The Sensory Menu & Flight Architect</h2>
                    <p class="text-gray-400 text-sm max-w-2xl mx-auto">
                        Compose your ideal dining program. Select our base courses and premium architectural additions to design your bespoke sensory path.
                    </p>
                </div>

                <!-- Menu Estimator Grid -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                    
                    <!-- Left Column: Course Selector -->
                    <div class="lg:col-span-7 space-y-8">
                        <h4 class="text-[10px] uppercase tracking-widest text-gray-500 font-bold">Select Base Gastronomy Volume</h4>
                        
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <!-- Course tier 1 -->
                            <div onclick="selectMenuTier(3, 195)" id="tier-3" class="menu-tier-card group p-5 bg-charcoal border border-goldChampagne/20 rounded cursor-pointer transition duration-300">
                                <span class="block font-serif-luxury text-2xl font-light text-goldChampagne">III</span>
                                <span class="block text-[10px] uppercase tracking-widest font-bold text-white mt-2">Prelude Flight</span>
                                <span class="block text-[9px] text-gray-500 mt-1">3 Culinary Masterpieces</span>
                                <span class="block font-serif-luxury text-lg text-white mt-3">$195/guest</span>
                            </div>

                            <!-- Course tier 2 -->
                            <div onclick="selectMenuTier(5, 295)" id="tier-5" class="menu-tier-card group p-5 bg-charcoal border border-white/5 hover:border-goldChampagne/30 rounded cursor-pointer transition duration-300">
                                <span class="block font-serif-luxury text-2xl font-light text-goldChampagne">V</span>
                                <span class="block text-[10px] uppercase tracking-widest font-bold text-white mt-2">Aether Symphony</span>
                                <span class="block text-[9px] text-gray-500 mt-1">5 Culinary Masterpieces</span>
                                <span class="block font-serif-luxury text-lg text-white mt-3">$295/guest</span>
                            </div>

                            <!-- Course tier 3 -->
                            <div onclick="selectMenuTier(7, 420)" id="tier-7" class="menu-tier-card group p-5 bg-charcoal border border-white/5 hover:border-goldChampagne/30 rounded cursor-pointer transition duration-300">
                                <span class="block font-serif-luxury text-2xl font-light text-goldChampagne">VII</span>
                                <span class="block text-[10px] uppercase tracking-widest font-bold text-white mt-2">Infinite Horizon</span>
                                <span class="block text-[9px] text-gray-500 mt-1">7 Culinary Masterpieces</span>
                                <span class="block font-serif-luxury text-lg text-white mt-3">$420/guest</span>
                            </div>
                        </div>

                        <!-- Addon Selectors -->
                        <div class="space-y-4 pt-4">
                            <h4 class="text-[10px] uppercase tracking-widest text-gray-500 font-bold">VIP Sommeliers & Rare Pairings</h4>
                            
                            <!-- Sommelier pairing 1 -->
                            <div onclick="toggleMenuAddon('Grand Cru Reserve Wine Program', 125, 'addon-1')" id="addon-1" class="group flex items-center justify-between p-5 bg-charcoal border border-white/5 hover:border-goldChampagne/30 rounded cursor-pointer transition duration-300">
                                <div class="flex items-center space-x-4">
                                    <div class="w-10 h-10 rounded bg-goldChampagne/5 border border-goldChampagne/20 flex items-center justify-center text-goldChampagne">
                                        <i class="fa-solid fa-wine-glass"></i>
                                    </div>
                                    <div>
                                        <span class="block text-[10px] uppercase tracking-widest font-bold text-white">Grand Cru Reserve Wine Program</span>
                                        <span class="text-[9px] text-gray-500">World-class vintage matches chosen per plate</span>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <span class="font-serif-luxury text-xs font-bold text-goldChampagne">+$125 / guest</span>
                                    <span id="addon-1-status" class="block text-[8px] text-gray-500 uppercase tracking-widest mt-1">Add</span>
                                </div>
                            </div>

                            <!-- Sommelier pairing 2 -->
                            <div onclick="toggleMenuAddon('Rare Altai Osetra Caviar Service', 95, 'addon-2')" id="addon-2" class="group flex items-center justify-between p-5 bg-charcoal border border-white/5 hover:border-goldChampagne/30 rounded cursor-pointer transition duration-300">
                                <div class="flex items-center space-x-4">
                                    <div class="w-10 h-10 rounded bg-goldChampagne/5 border border-goldChampagne/20 flex items-center justify-center text-goldChampagne">
                                        <i class="fa-solid fa-gem"></i>
                                    </div>
                                    <div>
                                        <span class="block text-[10px] uppercase tracking-widest font-bold text-white">Rare Altai Osetra Caviar Service</span>
                                        <span class="text-[9px] text-gray-500">Direct tableside preparation with pearl spoon accompaniment</span>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <span class="font-serif-luxury text-xs font-bold text-goldChampagne">+$95 / guest</span>
                                    <span id="addon-2-status" class="block text-[8px] text-gray-500 uppercase tracking-widest mt-1">Add</span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Right Panel: Dynamic Estimate Receipt -->
                    <div class="lg:col-span-5 bg-charcoal border border-goldChampagne/20 p-8 rounded-lg shadow-2xl relative">
                        <h3 class="font-serif-luxury text-xl font-bold text-white uppercase pb-4 border-b border-white/10">The Tasting Flight Blueprint</h3>
                        
                        <div class="py-6 space-y-4">
                            <!-- Dynamic Course Tier Row -->
                            <div class="flex justify-between text-[10px] uppercase tracking-widest text-gray-400">
                                <span>Selected Course Volume</span>
                                <span id="rec-tier" class="text-white font-bold">3 Courses prelude</span>
                            </div>
                            <div class="flex justify-between text-xs text-gray-300">
                                <span>Volume Base Cost</span>
                                <span id="rec-base-cost" class="font-serif-luxury text-goldChampagne font-bold">$195 / guest</span>
                            </div>

                            <!-- Applied Addons list -->
                            <div id="rec-applied-addons-box" class="space-y-3 pt-4 border-t border-white/5 hidden">
                                <span class="block text-[9px] uppercase tracking-widest text-gray-500 font-bold font-serif-luxury">Applied Fine Accompaniments</span>
                                <div id="rec-addons-items" class="space-y-2">
                                    <!-- Dynamic Items injected here -->
                                </div>
                            </div>
                        </div>

                        <div class="pt-6 border-t border-white/10 space-y-4">
                            <div class="flex justify-between items-baseline">
                                <span class="text-xs uppercase tracking-widest text-gray-500 font-bold">Estimated Cost per guest</span>
                                <span id="rec-total-cost" class="font-serif-luxury text-3xl font-light text-white">$195</span>
                            </div>
                            <p class="text-[8px] text-gray-500 leading-normal uppercase tracking-wider">
                                *All prices exclude state taxes and discretionary service gratuities. Volume plans booked per complete table only.
                            </p>
                            <button onclick="bookWithTastingDetails()" class="w-full py-4 bg-gradient-to-r from-goldChampagne to-amber-600 text-obsidian font-bold text-[10px] uppercase tracking-widest rounded transition duration-300">
                                Reserve Tasting Session
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- THE CHEF DE CUISINE -->
        <section id="chef" class="py-24 px-6 md:px-12 max-w-7xl mx-auto relative z-20">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                
                <!-- Chef Portrait/Graphic -->
                <div class="lg:col-span-6 order-last lg:order-first relative group">
                    <div class="absolute -inset-1 bg-gradient-to-r from-goldChampagne/30 to-bronzeAura/20 rounded-lg blur opacity-75 group-hover:opacity-100 transition duration-1000"></div>
                    <div class="relative bg-charcoal border border-white/10 p-2 rounded-lg">
                        <img src="https://images.unsplash.com/photo-1577219491135-ce391730fb2c?auto=format&fit=crop&q=80&w=800" alt="Chef Marc de L'Étoile" class="w-full h-[450px] object-cover rounded" onerror="this.src='https://placehold.co/800x600/141614/D4AF37?text=Chef+Marc+de+L%27%C3%89toile'">
                    </div>
                </div>

                <!-- Biography content -->
                <div class="lg:col-span-6 space-y-6">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-goldChampagne font-bold">The Master Mind</span>
                    <h2 class="font-serif-luxury text-4xl md:text-5xl font-light text-white leading-tight">Chef Marc de L'Étoile</h2>
                    <p class="text-gray-400 text-sm md:text-base leading-relaxed">
                        Recognized globally for his pioneering integration of thermodynamic science with classical French Escoffier foundations, Marc has led multiple legendary 3-Michelin-starred properties in Paris, Kyoto, and New York.
                    </p>
                    <p class="text-gray-400 text-sm leading-relaxed">
                        At AETHER, he strips away pretentious visual clutter to reveal the raw, unadulterated geometry of nature's flavors. "A plate must communicate not what we can change in nature, but what nature can transform inside ourselves."
                    </p>
                    
                    <div class="pt-6 border-t border-white/5 space-y-2">
                        <p class="font-serif-luxury text-lg italic text-goldChampagne">"Flavor is the true geometry of the human soul."</p>
                        <span class="block text-[8px] uppercase tracking-widest text-gray-500 font-bold">- Marc de L'Étoile</span>
                    </div>
                </div>

            </div>
        </section>

        <!-- BESPOKE ONLINE RESERVATION SECTION -->
        <section id="reservation" class="py-24 px-6 md:px-12 bg-charcoal/20 border-t border-white/5 relative z-20">
            <div class="max-w-4xl mx-auto space-y-12">
                <div class="text-center space-y-3">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-goldChampagne font-bold">Immediate Seatings</span>
                    <h2 class="font-serif-luxury text-4xl font-light text-white uppercase">Atmospheric Reservings</h2>
                    <p class="text-gray-400 text-sm max-w-xl mx-auto">
                        Secure a dining table at our main salon, chef's counter, or high-walled botanical terraces. Select your options below.
                    </p>
                </div>

                <!-- Custom Reservation Card with dynamic selection feedback -->
                <div class="glass-luxury-panel p-8 md:p-12 rounded-lg space-y-8">
                    <form onsubmit="event.preventDefault(); showToast('Private reservation files transmitted for priority verification.');" class="space-y-6">
                        
                        <!-- Row 1 inputs -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="space-y-2">
                                <label class="block text-[9px] uppercase tracking-widest text-gray-400 font-bold">Sensory Space</label>
                                <select class="w-full bg-obsidian border border-white/10 rounded p-3 text-[10px] uppercase tracking-wider text-white focus:border-goldChampagne focus:outline-none">
                                    <option value="Main Salon">The Main Salon</option>
                                    <option value="Chef Counter">The Chef's Counter (Thermodynamic View)</option>
                                    <option value="Private Terrace">Botanical Terraces</option>
                                </select>
                            </div>

                            <div class="space-y-2">
