        // LOGISTICS FORM EXECUTIONS
        function triggerSearchQuery() {
            const loc = document.getElementById('logistics-pickup').value;
            const start = document.getElementById('logistics-date-start').value;
            const end = document.getElementById('logistics-date-end').value;
            showToast(`Scanned Runway: ${loc}. Filtered from ${start} to ${end}.`);
        }


        // ==========================================
        // RATE ESTIMATOR & PRIVILEGE SUITE CODE
        // ==========================================
        let estimatorState = {
            basePrice: 1800,
            days: 3,
            addones: []
        };

        function updateEstimator() {
            const selectEl = document.getElementById('estimator-car');
            const selectedOpt = selectEl.options[selectEl.selectedIndex];
            estimatorState.basePrice = parseFloat(selectedOpt.getAttribute('data-price'));

            const daysVal = document.getElementById('estimator-days').value;
            estimatorState.days = parseInt(daysVal);
            document.getElementById('estimator-days-val').innerText = daysVal;

            renderEstimatorSummary();
        }

        function toggleEstimatorPrivilege(name, price, elementId) {
            const index = estimatorState.addones.findIndex(item => item.name === name);
            const card = document.getElementById(elementId);
            const statusLabel = document.getElementById(`${elementId}-status`);

            if (index > -1) {
                // Remove addon
                estimatorState.addones.splice(index, 1);
                card.classList.remove('border-neonCyan');
                statusLabel.innerText = 'Add';
                statusLabel.classList.remove('text-neonCyan');
                statusLabel.classList.add('text-gray-500');
                showToast(`Removed privileged accessory: ${name}`);
            } else {
                // Add addon
                estimatorState.addones.push({ name, price });
                card.classList.add('border-neonCyan');
                statusLabel.innerText = 'Applied';
                statusLabel.classList.remove('text-gray-500');
                statusLabel.classList.add('text-neonCyan');
                showToast(`Applied privileged accessory: ${name}`);
            }

            renderEstimatorSummary();
        }

        function renderEstimatorSummary() {
            const listContainer = document.getElementById('estimator-addons-list');
            const itemsContainer = document.getElementById('estimator-addons-items');
            
            if (estimatorState.addones.length === 0) {
                listContainer.classList.add('hidden');
            } else {
                listContainer.classList.remove('hidden');
                itemsContainer.innerHTML = '';
                estimatorState.addones.forEach(add => {
                    const div = document.createElement('div');
                    div.className = 'flex justify-between text-xs text-gray-300';
                    div.innerHTML = `<span>${add.name}</span><span class="text-neonCyan font-bold">+$${add.price}</span>`;
                    itemsContainer.appendChild(div);
                });
            }

            // Calculation Matrix
            let addonsTotal = estimatorState.addones.reduce((sum, add) => sum + add.price, 0);
            let total = (estimatorState.basePrice * estimatorState.days) + addonsTotal;
            document.getElementById('estimator-total').innerText = `$${total.toLocaleString()}`;
        }

        function bookWithEstimateDetails() {
            const selectEl = document.getElementById('estimator-car');
            const carName = selectEl.options[selectEl.selectedIndex].value;
