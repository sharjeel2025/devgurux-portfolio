                        <!-- High performance sports car visual representation -->
                        <img src="https://images.unsplash.com/photo-1583121274602-3e2820c69888?auto=format&fit=crop&q=80&w=600" alt="Apex GT F90" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" onerror="this.src='https://placehold.co/600x400/0C0C0B/00F2FE?text=Apex+GT+F90'">
                        <span class="absolute top-4 right-4 px-3 py-1 bg-obsidian/80 border border-neonCyan/30 rounded text-[9px] tracking-widest uppercase text-neonCyan font-bold">Hybrid V8</span>
                    </div>
                    <div class="p-6 space-y-6">
                        <div class="flex justify-between items-baseline">
                            <h3 class="font-display text-xl font-bold text-white uppercase tracking-tight">Apex GT F90</h3>
                            <div class="text-right">
                                <span class="font-display text-lg font-bold text-neonCyan">$2,400</span>
                                <span class="text-[9px] text-gray-500 uppercase tracking-wider block">/ Day</span>
                            </div>
                        </div>

                        <!-- Technical Matrix -->
                        <div class="grid grid-cols-3 gap-2 text-center text-[10px] text-gray-400 tracking-wider uppercase bg-obsidian/60 p-3 rounded">
                            <div>
                                <i class="fa-solid fa-gauge text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">1000 hp</span>
                                <span>Engine</span>
                            </div>
                            <div>
                                <i class="fa-solid fa-stopwatch text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">2.5s</span>
                                <span>0-60 mph</span>
                            </div>
                            <div>
                                <i class="fa-solid fa-bolt text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">340 km/h</span>
                                <span>Top Speed</span>
                            </div>
                        </div>

                        <!-- Card actions -->
                        <div class="flex space-x-3">
                            <button onclick="requestCarQuote('Apex GT F90', 2400)" class="flex-1 py-3 bg-neonCyan text-obsidian font-black text-xs uppercase tracking-widest text-center rounded hover:bg-white transition-all duration-300 shadow shadow-neonCyan/10">
                                Reserve Now
                            </button>
                            <button onclick="viewCarDetails('Apex GT F90', 'Hybrid Hypercar representing absolute Italian racing heritage combined with extreme tri-electric-motor setups.')" class="px-4 py-3 border border-white/10 hover:border-neonCyan text-gray-400 hover:text-white rounded transition">
                                <i class="fa-solid fa-circle-info"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Vehicle Card 2 (Porsche) -->
                <div class="fleet-card group bg-carbon/80 border border-white/5 rounded-xl overflow-hidden hover:border-neonCyan/30 transition-all duration-300" data-category="Sport" data-price="1800" data-name="Veloce RS 911">
                    <div class="h-56 overflow-hidden relative bg-black/40">
                        <img src="https://images.unsplash.com/photo-1614162692292-7ac56d7f7f1e?auto=format&fit=crop&q=80&w=600" alt="Veloce RS 911" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" onerror="this.src='https://placehold.co/600x400/0C0C0B/00F2FE?text=Veloce+RS+911'">
                        <span class="absolute top-4 right-4 px-3 py-1 bg-obsidian/80 border border-neonCyan/30 rounded text-[9px] tracking-widest uppercase text-neonCyan font-bold">Naturally Aspirated</span>
                    </div>
                    <div class="p-6 space-y-6">
                        <div class="flex justify-between items-baseline">
                            <h3 class="font-display text-xl font-bold text-white uppercase tracking-tight">Veloce RS 911</h3>
                            <div class="text-right">
                                <span class="font-display text-lg font-bold text-neonCyan">$1,800</span>
                                <span class="text-[9px] text-gray-500 uppercase tracking-wider block">/ Day</span>
                            </div>
                        </div>

                        <!-- Technical Matrix -->
                        <div class="grid grid-cols-3 gap-2 text-center text-[10px] text-gray-400 tracking-wider uppercase bg-obsidian/60 p-3 rounded">
                            <div>
                                <i class="fa-solid fa-gauge text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">525 hp</span>
                                <span>Flat-6</span>
                            </div>
                            <div>
                                <i class="fa-solid fa-stopwatch text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">3.0s</span>
                                <span>0-60 mph</span>
                            </div>
                            <div>
                                <i class="fa-solid fa-bolt text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">296 km/h</span>
                                <span>Track-Prepped</span>
                            </div>
                        </div>

                        <!-- Card actions -->
                        <div class="flex space-x-3">
                            <button onclick="requestCarQuote('Veloce RS 911', 1800)" class="flex-1 py-3 bg-neonCyan text-obsidian font-black text-xs uppercase tracking-widest text-center rounded hover:bg-white transition-all duration-300 shadow shadow-neonCyan/10">
                                Reserve Now
                            </button>
                            <button onclick="viewCarDetails('Veloce RS 911', 'The quintessential track weapon. Flawless active aerodynamics, dry sump lubrication, and lightweight carbon composition.')" class="px-4 py-3 border border-white/10 hover:border-neonCyan text-gray-400 hover:text-white rounded transition">
                                <i class="fa-solid fa-circle-info"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Vehicle Card 3 (EV Hypercar) -->
                <div class="fleet-card group bg-carbon/80 border border-white/5 rounded-xl overflow-hidden hover:border-neonCyan/30 transition-all duration-300" data-category="EV" data-price="3200" data-name="Zephyr-E Concept">
                    <div class="h-56 overflow-hidden relative bg-black/40">
                        <img src="https://images.unsplash.com/photo-1563720223185-11003d516935?auto=format&fit=crop&q=80&w=600" alt="Zephyr-E Concept" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" onerror="this.src='https://placehold.co/600x400/0C0C0B/00F2FE?text=Zephyr-E+Concept'">
                        <span class="absolute top-4 right-4 px-3 py-1 bg-obsidian/80 border border-neonCyan/30 rounded text-[9px] tracking-widest uppercase text-neonCyan font-bold">Solid State EV</span>
                    </div>
                    <div class="p-6 space-y-6">
                        <div class="flex justify-between items-baseline">
                            <h3 class="font-display text-xl font-bold text-white uppercase tracking-tight">Zephyr-E Concept</h3>
                            <div class="text-right">
                                <span class="font-display text-lg font-bold text-neonCyan">$3,200</span>
                                <span class="text-[9px] text-gray-500 uppercase tracking-wider block">/ Day</span>
                            </div>
                        </div>

                        <!-- Technical Matrix -->
                        <div class="grid grid-cols-3 gap-2 text-center text-[10px] text-gray-400 tracking-wider uppercase bg-obsidian/60 p-3 rounded">
                            <div>
                                <i class="fa-solid fa-gauge text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">1900 hp</span>
                                <span>Quad Motor</span>
                            </div>
                            <div>
                                <i class="fa-solid fa-stopwatch text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">1.8s</span>
                                <span>0-60 mph</span>
                            </div>
                            <div>
                                <i class="fa-solid fa-bolt text-neonCyan block mb-1 text-sm"></i>
                                <span class="text-white font-bold block text-xs">412 km/h</span>
                                <span>Hyper Electric</span>
                            </div>
                        </div>

                        <!-- Card actions -->
                        <div class="flex space-x-3">
                            <button onclick="requestCarQuote('Zephyr-E Concept', 3200)" class="flex-1 py-3 bg-neonCyan text-obsidian font-black text-xs uppercase tracking-widest text-center rounded hover:bg-white transition-all duration-300 shadow shadow-neonCyan/10">
                                Reserve Now
                            </button>
                            <button onclick="viewCarDetails('Zephyr-E Concept', 'Unrivaled instant torque. State-of-the-art vectoring systems powering individual wheels for space-like dynamics.')" class="px-4 py-3 border border-white/10 hover:border-neonCyan text-gray-400 hover:text-white rounded transition">
                                <i class="fa-solid fa-circle-info"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Vehicle Card 4 (Lamborghini SUV) -->
                <div class="fleet-card group bg-carbon/80 border border-white/5 rounded-xl overflow-hidden hover:border-neonCyan/30 transition-all duration-300" data-category="SuperSUV" data-price="1950" data-name="Aero-Wulf SUV">
                    <div class="h-56 overflow-hidden relative bg-black/40">
                        <img src="https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?auto=format&fit=crop&q=80&w=600" alt="Aero-Wulf SUV" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" onerror="this.src='https://placehold.co/600x400/0C0C0B/00F2FE?text=Aero-Wulf+SUV'">
