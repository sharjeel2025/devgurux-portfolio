        // ==========================================
        // THREE.JS 3D CINEMATIC HYPERCAR VIEWPORT
        // ==========================================
        let scene, camera, renderer, carGroup, environmentParticles;
        let ambientLight, directionalLight, sideKeyLight, rimGoldLight, headlightsLight, underglowLight;

        let isDragging = false;
        let previousMousePosition = { x: 0, y: 0 };
        let dragRotationOffset = { x: 0, y: 0 };
        let targetDragRotationOffset = { x: 0, y: 0 };

        // capture window scrolls target for physics interpolation
        let scrollY = 0;
        let lerpScrollY = 0;

        window.addEventListener('scroll', () => {
            scrollY = window.scrollY;
        });

        function setupInteractiveDrag() {
            const interactiveZone = document.getElementById('hero-3d-interactive-zone');
            if (!interactiveZone) return;

            // Mouse tracking handlers
            interactiveZone.addEventListener('mousedown', (e) => {
                isDragging = true;
                previousMousePosition = { x: e.clientX, y: e.clientY };
            });

            window.addEventListener('mouseup', () => {
                isDragging = false;
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                const deltaMove = {
                    x: e.clientX - previousMousePosition.x,
                    y: e.clientY - previousMousePosition.y
                };

                targetDragRotationOffset.y += deltaMove.x * 0.007;
                targetDragRotationOffset.x += deltaMove.y * 0.007;

                previousMousePosition = { x: e.clientX, y: e.clientY };
            });

            // Touch tracking handlers for mobiles/tablets
            interactiveZone.addEventListener('touchstart', (e) => {
                isDragging = true;
                const touch = e.touches[0];
                previousMousePosition = { x: touch.clientX, y: touch.clientY };
            }, { passive: true });

            window.addEventListener('touchmove', (e) => {
                if (!isDragging) return;
                const touch = e.touches[0];
                const deltaMove = {
                    x: touch.clientX - previousMousePosition.x,
                    y: touch.clientY - previousMousePosition.y
                };

                targetDragRotationOffset.y += deltaMove.x * 0.007;
                targetDragRotationOffset.x += deltaMove.y * 0.007;

                previousMousePosition = { x: touch.clientX, y: touch.clientY };
            }, { passive: true });

            window.addEventListener('touchend', () => {
                isDragging = false;
            });
        }

        function buildCinematicThreeJS() {
            const viewport = document.getElementById('canvas-viewport');
            const width = window.innerWidth;
            const height = window.innerHeight;

            scene = new THREE.Scene();

            camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 100);
            camera.position.set(0, 1.8, 11);

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(width, height);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            viewport.appendChild(renderer.domElement);

            // INITIALIZE HYPERCAR PROCEDURAL COMPONENTS
            carGroup = new THREE.Group();

            // 1. CAR CORE BODY (Aerodynamic Chassis with high-gloss metallic paint)
            const bodyGeo = new THREE.BoxGeometry(2.2, 0.45, 4.8);
            const metallicChassisMaterial = new THREE.MeshPhysicalMaterial({
                color: 0xE2E8F0,          // Luxurious Brushed Platinum Silver for excellent dark-theme contrast
                roughness: 0.1,           // Extremely sleek surface reflections
                metalness: 0.95,          // Metallic core highlight shine
                clearcoat: 1.0,           // Gloss finish
                clearcoatRoughness: 0.05
            });
            const chassis = new THREE.Mesh(bodyGeo, metallicChassisMaterial);
            carGroup.add(chassis);

            // Sleek hood scoop nose
            const noseGeo = new THREE.BoxGeometry(2.0, 0.24, 1.4);
            const nose = new THREE.Mesh(noseGeo, metallicChassisMaterial);
            nose.position.set(0, -0.05, 2.7);
            carGroup.add(nose);

            // Dynamic side panels highlighting chassis curves
            const panelLGeo = new THREE.BoxGeometry(0.12, 0.35, 2.4);
            const panelL = new THREE.Mesh(panelLGeo, metallicChassisMaterial);
            panelL.position.set(-1.12, 0.05, 0);
            const panelR = panelL.clone();
            panelR.position.x = 1.12;
            carGroup.add(panelL);
            carGroup.add(panelR);

            // Aerodynamic Obsidian Glass Canopy (Transparent-infused)
            const canopyGeo = new THREE.BoxGeometry(1.6, 0.42, 1.9);
            const canopyMaterial = new THREE.MeshPhysicalMaterial({
                color: 0x0A0A0C,          // Dark Obsidian glass
                roughness: 0.02,
                metalness: 0.9,
                transmission: 0.5,
                transparent: true
            });
            const canopy = new THREE.Mesh(canopyGeo, canopyMaterial);
            canopy.position.set(0, 0.38, -0.3);
            carGroup.add(canopy);

            // Lightweight carbon spanner posts for spoiler wing
            const carbonMaterial = new THREE.MeshStandardMaterial({ color: 0x1a1a1f, roughness: 0.5 });
            const wingSpannersGeo = new THREE.BoxGeometry(0.08, 0.5, 0.3);
            const spannerL = new THREE.Mesh(wingSpannersGeo, carbonMaterial);
            spannerL.position.set(-0.85, 0.38, -2.1);
            const spannerR = spannerL.clone();
            spannerR.position.x = 0.85;
            carGroup.add(spannerL);
            carGroup.add(spannerR);

            // Rear spoiler wing
            const wingGeo = new THREE.BoxGeometry(2.3, 0.06, 0.65);
            const wing = new THREE.Mesh(wingGeo, metallicChassisMaterial);
            wing.position.set(0, 0.62, -2.1);
            carGroup.add(wing);

            // Glowing High-Intensity Headlight Grid
            const lightBarGeo = new THREE.BoxGeometry(1.7, 0.05, 0.1);
            const headlightMaterial = new THREE.MeshStandardMaterial({
                color: 0x00F2FE,
                emissive: 0x00F2FE,
                emissiveIntensity: 5.5
            });
            const headlampBar = new THREE.Mesh(lightBarGeo, headlightMaterial);
            headlampBar.position.set(0, -0.06, 3.4);
            carGroup.add(headlampBar);

            // Laser Glowing Rear taillight bar
            const taillightGeo = new THREE.BoxGeometry(2.1, 0.03, 0.08);
            const taillightMaterial = new THREE.MeshStandardMaterial({
                color: 0xff0033,
                emissive: 0xff0033,
                emissiveIntensity: 6.0
            });
            const taillight = new THREE.Mesh(taillightGeo, taillightMaterial);
            taillight.position.set(0, 0.12, -2.4);
            carGroup.add(taillight);

            // 2. SPORTS WHEELS & ROTOR CALIPERS
            const wheelTireGeo = new THREE.CylinderGeometry(0.58, 0.58, 0.38, 32);
            const wheelRimGeo = new THREE.CylinderGeometry(0.44, 0.44, 0.39, 16);
            const caliperGeo = new THREE.BoxGeometry(0.1, 0.28, 0.12);

            const rubberMaterial = new THREE.MeshStandardMaterial({ color: 0x08080a, roughness: 0.95 });
            const rimMetallicMaterial = new THREE.MeshStandardMaterial({
                color: 0xD4AF37,          // Classic racing bronze/gold rims
                metalness: 0.95,
                roughness: 0.2
            });
            const caliperNeonMaterial = new THREE.MeshStandardMaterial({
                color: 0x39FF14,          // Neon Green racing calipers
                emissive: 0x39FF14,
                emissiveIntensity: 1.5
            });

            // Assemble Wheel Setup helper
            function createWheelAssemble(posX, posY, posZ) {
                const assembly = new THREE.Group();
                
                // Tire
                const tireMesh = new THREE.Mesh(wheelTireGeo, rubberMaterial);
                assembly.add(tireMesh);

                // Multi-spoke Rim
                const rimMesh = new THREE.Mesh(wheelRimGeo, rimMetallicMaterial);
                rimMesh.rotation.x = Math.PI / 2;
                assembly.add(rimMesh);

                // Rotor Caliper
                const caliperMesh = new THREE.Mesh(caliperGeo, caliperNeonMaterial);
                caliperMesh.position.set(0.35, 0, 0);
                assembly.add(caliperMesh);

                assembly.rotation.z = Math.PI / 2;
                assembly.position.set(posX, posY, posZ);
                return assembly;
            }

            const wheelL1 = createWheelAssemble(-1.16, -0.22, 1.6);
            const wheelR1 = createWheelAssemble(1.16, -0.22, 1.6);
            const wheelL2 = createWheelAssemble(-1.16, -0.22, -1.6);
            const wheelR2 = createWheelAssemble(1.16, -0.22, -1.6);

            // Flip right side components to match visual orientation
            wheelR1.rotation.y = Math.PI;
            wheelR2.rotation.y = Math.PI;

            carGroup.add(wheelL1);
            carGroup.add(wheelR1);
            carGroup.add(wheelL2);
            carGroup.add(wheelR2);

            // Active glowing jet engine exhaust cones
            const exhaustGeo = new THREE.ConeGeometry(0.12, 0.4, 16);
            const exhaustFlameMat = new THREE.MeshBasicMaterial({
                color: 0x00F2FE,
                transparent: true,
                opacity: 0.9
            });
            const jetL = new THREE.Mesh(exhaustGeo, exhaustFlameMat);
            jetL.rotation.x = -Math.PI / 2;
            jetL.position.set(-0.5, -0.15, -2.42);
            const jetR = jetL.clone();
            jetR.position.x = 0.5;
            carGroup.add(jetL);
            carGroup.add(jetR);

            // Add complete hypercar assembly to scene coordinate framework
            scene.add(carGroup);

            // 3. UNDERGLOW CYAN AMBIENCE
            underglowLight = new THREE.PointLight(0x00F2FE, 8, 14);
            underglowLight.position.set(0, -0.7, 0);
            carGroup.add(underglowLight);

            // Visual neon mesh plane reflecting simulated underglow on flooring
            const glowPlaneGeo = new THREE.PlaneGeometry(2.4, 4.6);
            const glowPlaneMat = new THREE.MeshBasicMaterial({
                color: 0x00F2FE,
                transparent: true,
                opacity: 0.15,
                side: THREE.DoubleSide
            });
            const glowDisc = new THREE.Mesh(glowPlaneGeo, glowPlaneMat);
            glowDisc.rotation.x = Math.PI / 2;
            glowDisc.position.y = -0.58;
            carGroup.add(glowDisc);


            // ENVIRONMENT PARTICLES SYSTEM (Coastal light streaks passing by)
            const particlesCount = 220;
            const particleGeo = new THREE.BufferGeometry();
            const positionsArray = new Float32Array(particlesCount * 3);

            for (let i = 0; i < particlesCount * 3; i += 3) {
                positionsArray[i] = (Math.random() - 0.5) * 40;     // X scatter
                positionsArray[i + 1] = (Math.random() - 0.5) * 25; // Y scatter
                positionsArray[i + 2] = (Math.random() - 0.5) * 45; // Z depth scatter
            }

            particleGeo.setAttribute('position', new THREE.BufferAttribute(positionsArray, 3));

            const particleMaterial = new THREE.PointsMaterial({
                size: 0.08,
                color: 0x00F2FE,
                transparent: true,
                opacity: 0.65,
                blending: THREE.AdditiveBlending
            });

            environmentParticles = new THREE.Points(particleGeo, particleMaterial);
            scene.add(environmentParticles);


            // DRAMATIC STUDIO LIGHTING STAGE
            ambientLight = new THREE.AmbientLight(0xffffff, 0.4); // Bright baseline ambient light
            scene.add(ambientLight);

            // Bright Key light from top-front to make platinum paint shine
            directionalLight = new THREE.DirectionalLight(0xffffff, 3.5);
            directionalLight.position.set(6, 15, 8);
            scene.add(directionalLight);

            // Intense blue back/side fill key highlight
            sideKeyLight = new THREE.DirectionalLight(0x00F2FE, 3.2);
            sideKeyLight.position.set(-8, 3, -6);
            scene.add(sideKeyLight);

            // Luxury Warm gold rim light to wrap around the edges
            rimGoldLight = new THREE.DirectionalLight(0xD4AF37, 2.5);
            rimGoldLight.position.set(0, -6, -8);
            scene.add(rimGoldLight);

            window.addEventListener('resize', onWindowResize);
            
            // Apply scale fitting check
            applyResponsiveFit();

            setupInteractiveDrag();

            // Start rendering cycle
            animateCinematic();
        }

        // AUTO SCALE CORRECTION FOR SCREEN FITTING
        function applyResponsiveFit() {
            if (!carGroup) return;
            const width = window.innerWidth;
            
            if (width < 640) {
                // Mobile size optimization
                carGroup.scale.set(0.55, 0.55, 0.55);
            } else if (width < 1024) {
                // Tablet size optimization
                carGroup.scale.set(0.78, 0.78, 0.78);
            } else {
                // Large desktop dimensions
                carGroup.scale.set(1.05, 1.05, 1.05);
            }
        }

        function onWindowResize() {
            const width = window.innerWidth;
            const height = window.innerHeight;

            camera.aspect = width / height;
            camera.updateProjectionMatrix();

            renderer.setSize(width, height);
            applyResponsiveFit();
        }

        // Kinetic Animation Render Loop
        let rotationTimer = 0;
        function animateCinematic() {
            requestAnimationFrame(animateCinematic);
            rotationTimer += 0.015;

            // Interpolated Scroll Metrics (Buttery-smooth Lerp)
            lerpScrollY += (scrollY - lerpScrollY) * 0.05;

            const docHeight = document.documentElement.scrollHeight - window.innerHeight || 1;
            const scrollFraction = Math.min(lerpScrollY / docHeight, 1.0);

            // WHEEL SPINNING MOTION PHYSICS
            carGroup.children.forEach(child => {
                // Rotate specific assemblies corresponding to sports wheels
                if (child.position.x === -1.16 || child.position.x === 1.16) {
                    child.rotation.x = rotationTimer * 1.6 + (scrollFraction * 40.0);
                }
            });

            if (!isDragging) {
                // Smoothly decay/return drag offsets back to zero when user lets go
                targetDragRotationOffset.x *= 0.95;
                targetDragRotationOffset.y *= 0.95;
            }

            dragRotationOffset.x += (targetDragRotationOffset.x - dragRotationOffset.x) * 0.15;
            dragRotationOffset.y += (targetDragRotationOffset.y - dragRotationOffset.y) * 0.15;

            // CINEMATIC SCROLL STORYBOARD CAMERA CHOREOGRAPHY
            if (carGroup) {
                const isMobile = window.innerWidth < 768;

                if (isMobile) {
                    // Mobile Layout: Center hypercar perfectly to stay visible between overlays
                    carGroup.position.x = 0;
                    carGroup.position.y = -0.4 + (scrollFraction * 0.8);
                    carGroup.position.z = -1.0 + (scrollFraction * 2.0);

                    // Moderate rotational presentation combined with drag offset interaction
                    carGroup.rotation.x = dragRotationOffset.x + (0.05 + Math.sin(rotationTimer * 0.5) * 0.02);
                    carGroup.rotation.y = dragRotationOffset.y + (rotationTimer * 0.06 + (scrollFraction * Math.PI * 1.6));
                } else {
                    // Desktop Layout: Orchestrated middle-right storytelling path
                    // Phase 1 (Hero): Centered perfectly on the middle right zone matching interactive element
                    // Phase 2 (Catalog): Move left and up as layout scrolls down
                    carGroup.position.x = 2.4 - (scrollFraction * 4.8);
                    carGroup.position.y = 0.0 + (scrollFraction * 1.2);
                    carGroup.position.z = 0.0 + (scrollFraction * 1.5);

                    // Dynamic multi-perspective sweeping turn mapping combined with user's live drag offsets
                    carGroup.rotation.x = dragRotationOffset.x + (Math.sin(rotationTimer * 0.4) * 0.03 + (scrollFraction * 0.15));
                    carGroup.rotation.y = dragRotationOffset.y + (rotationTimer * 0.04 + (scrollFraction * Math.PI * 2.0));
                    carGroup.rotation.z = Math.cos(rotationTimer * 0.4) * 0.02;
                }

                // Smooth passive vertical hovering oscillation
                carGroup.position.y += Math.sin(rotationTimer * 1.2) * 0.012;
            }

            // Space particle speed adjustments tied to scrolling momentum
            if (environmentParticles) {
                const positions = environmentParticles.geometry.attributes.position.array;
                for (let i = 0; i < positions.length; i += 3) {
                    positions[i + 2] += 0.09 + (scrollFraction * 0.5); // Moves toward Z-camera
                    if (positions[i + 2] > 22) {
                        positions[i + 2] = -22; // depth loop
                    }
                }
                environmentParticles.geometry.attributes.position.needsUpdate = true;
            }

            renderer.render(scene, camera);
        }

        // Initialize cinematic showcase on page loads
        window.onload = function () {
            buildCinematicThreeJS();
        }
    </script>

    <!-- CUSTOM FLOATING CALIBRATION TOAST -->
    <div id="custom-toast" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 bg-carbon border border-neonCyan p-4 rounded-md shadow-2xl flex items-center space-x-3 transition-all duration-500 max-w-sm pointer-events-none">
        <div class="w-8 h-8 rounded-full bg-neonCyan/10 flex items-center justify-center text-neonCyan">
            <i class="fa-solid fa-radar text-sm animate-pulse"></i>
        </div>
        <div>
            <p id="toast-message" class="text-xs font-bold text-white tracking-widest uppercase">System notification status</p>
        </div>
    </div>

