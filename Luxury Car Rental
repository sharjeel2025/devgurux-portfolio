<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VELOCE | Elite Hypercar Atelier & Luxury Rentals</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        obsidian: '#060608',
                        carbon: '#0F0F13',
                        neonCyan: '#00F2FE',
                        neonGreen: '#39FF14',
                        platinum: '#E2E8F0',
                        cyanGlow: 'rgba(0, 242, 254, 0.15)',
                    },
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                        display: ['Space Grotesk', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Three.js Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #060608;
            color: #E2E8F0;
            overflow-x: hidden;
        }
        .font-display {
            font-family: 'Space Grotesk', sans-serif;
        }
        /* Custom scrollbar matching the metallic accent */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #060608;
        }
        ::-webkit-scrollbar-thumb {
            background: #00F2FE;
            border-radius: 3px;
        }
        /* Fixed full-screen backdrop canvas */
        #canvas-viewport {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 1; /* Position behind content but accessible if needed */
            pointer-events: none; /* Allows clicks to penetrate to standard layout buttons */
        }
        .neon-shadow {
            box-shadow: 0 0 25px rgba(0, 242, 254, 0.25);
        }
        .neon-border-hover:hover {
            border-color: #00F2FE;
            box-shadow: 0 0 20px rgba(0, 242, 254, 0.15);
        }
        /* Glassmorphic card styling */
        .glass-card {
            background: rgba(15, 15, 19, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="bg-obsidian text-platinum selection:bg-neonCyan selection:text-obsidian">

    <!-- PRELOADER -->
    <div id="preloader" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-obsidian transition-opacity duration-1000">
        <div class="text-center space-y-4">
            <h1 class="font-display text-6xl font-bold tracking-[0.3em] text-white animate-pulse">VELOCE</h1>
            <p class="text-xs uppercase tracking-[0.5em] text-neonCyan">Exotic Hypercar Atelier</p>
            <div class="w-32 h-[2px] bg-gradient-to-r from-transparent via-neonCyan to-transparent mx-auto mt-6"></div>
        </div>
    </div>

    <!-- IMMERSIVE 3D CANVA VIEWPORT BACKGROUND -->
    <div id="canvas-viewport">
        <!-- Three.js renders the custom hypercar here -->
    </div>

    <!-- NAVIGATION HEADER -->
    <header class="fixed top-0 left-0 w-full z-40 transition-all duration-300 bg-obsidian/40 backdrop-blur-md border-b border-white/5">
        <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
            <a href="#" class="font-display text-3xl font-black tracking-widest text-white hover:text-neonCyan transition">
                VELOCE<span class="text-neonCyan font-normal">.</span>
            </a>
            
            <!-- Desktop Links -->
            <nav class="hidden lg:flex items-center space-x-8 text-xs uppercase tracking-widest font-semibold text-gray-400">
                <a href="#hero" class="hover:text-white hover:underline decoration-neonCyan decoration-2 underline-offset-4 transition">Home</a>
                <a href="#fleet" class="hover:text-white hover:underline decoration-neonCyan decoration-2 underline-offset-4 transition">Atelier Fleet</a>
                <a href="#estimator" class="hover:text-white hover:underline decoration-neonCyan decoration-2 underline-offset-4 transition">Rate Planner</a>
                <a href="#membership" class="hover:text-white hover:underline decoration-neonCyan decoration-2 underline-offset-4 transition">Club Privé</a>
                <a href="#faq" class="hover:text-white hover:underline decoration-neonCyan decoration-2 underline-offset-4 transition">Assistance</a>
            </nav>

            <!-- Call to Actions -->
            <div class="flex items-center space-x-4">
                <button onclick="openBookingModal()" class="px-6 py-2.5 bg-gradient-to-r from-neonCyan to-blue-600 hover:from-white hover:to-white text-obsidian font-bold text-xs uppercase tracking-widest transition-all duration-300 rounded shadow-lg shadow-neonCyan/20">
                    Reserve Séance
                </button>
                <button id="mobile-toggle" class="lg:hidden text-white focus:outline-none p-2">
                    <i class="fa-solid fa-bars-staggered text-xl"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Drawer Menu -->
        <div id="mobile-drawer" class="hidden lg:hidden bg-obsidian border-t border-white/5 px-6 py-6 absolute top-full left-0 w-full flex flex-col space-y-4 text-xs uppercase tracking-widest text-gray-300">
            <a href="#hero" class="drawer-link py-2 border-b border-white/5 hover:text-neonCyan transition">Home</a>
            <a href="#fleet" class="drawer-link py-2 border-b border-white/5 hover:text-neonCyan transition">Atelier Fleet</a>
            <a href="#estimator" class="drawer-link py-2 border-b border-white/5 hover:text-neonCyan transition">Rate Planner</a>
            <a href="#membership" class="drawer-link py-2 border-b border-white/5 hover:text-neonCyan transition">Club Privé</a>
            <a href="#faq" class="drawer-link py-2 border-b border-white/5 hover:text-neonCyan transition">Assistance</a>
            <button onclick="openBookingModal(); toggleDrawer();" class="w-full mt-4 py-3 bg-neonCyan text-obsidian font-bold text-center uppercase tracking-widest hover:bg-white transition">
                Reserve Séance
            </button>
        </div>
    </header>

    <!-- CONTENT SCROLL CONTROLLERS (Overlay layers on top of 3D fixed background) -->
    <main class="relative z-10">

        <!-- HERO INTRODUCTION (Phased 1 of 3D Story) -->
        <section id="hero" class="min-h-screen flex items-center justify-start px-6 md:px-12 lg:px-24 py-16 bg-transparent relative">
            <div class="max-w-xl lg:max-w-2xl space-y-8 text-left relative z-20">
                <div class="inline-flex items-center space-x-3 px-3 py-1 border border-neonCyan/30 rounded bg-neonCyan/5 text-neonCyan text-xs tracking-widest uppercase animate-pulse">
                    <span class="w-1.5 h-1.5 rounded-full bg-neonCyan"></span>
                    <span>Exclusive Runway Concierge Now Open</span>
                </div>

                <h1 class="font-display text-5xl sm:text-7xl lg:text-8xl font-black tracking-tight leading-none text-white uppercase">
                    Drive the <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-neonCyan via-blue-500 to-indigo-600">Future.</span>
                </h1>

                <p class="text-gray-400 text-base md:text-lg max-w-xl leading-relaxed">
                    Unleash raw, untamed performance. Access a hyper-curated collection of elite sports machinery and conceptual electric hypercars for track or coastal touring.
                </p>

                <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-4 max-w-md">
                    <a href="#fleet" class="px-8 py-4 bg-white hover:bg-neonCyan text-obsidian font-bold text-center text-xs uppercase tracking-widest rounded transition duration-300">
                        Explore Fleet
                    </a>
                    <button onclick="openBookingModal()" class="px-8 py-4 border border-white/20 hover:border-neonCyan text-center text-white hover:text-neonCyan text-xs uppercase tracking-widest font-bold rounded transition duration-300 backdrop-blur-sm">
                        Instantly Book
                    </button>
                </div>

                <div class="flex items-center space-x-4 pt-8 text-xs text-gray-500 tracking-widest uppercase">
                    <i class="fa-solid fa-circle-chevron-down text-neonCyan animate-bounce"></i>
                    <span>Scroll to Inspect Chassis contours</span>
                </div>
            </div>

            <div id="hero-3d-interactive-zone" class="absolute right-0 lg:right-12 xl:right-24 top-1/2 -translate-y-1/2 w-full lg:w-[45%] h-[350px] lg:h-[550px] z-30 pointer-events-auto cursor-grab active:cursor-grabbing">
                <!-- Floating badge instructing user -->
                <div class="absolute bottom-4 right-4 bg-obsidian/85 backdrop-blur-md px-4 py-2 border border-neonCyan/30 rounded text-[10px] tracking-widest uppercase text-neonCyan font-bold pointer-events-none select-none flex items-center space-x-2">
                    <i class="fa-solid fa-arrows-spin animate-spin"></i>
                    <span>Drag / Swipe to Spin Hypercar</span>
                </div>
            </div>

            <!-- Visual ambient lights in landing frame -->
            <div class="absolute right-10 top-1/4 w-[350px] h-[350px] bg-neonCyan/5 rounded-full blur-[100px] pointer-events-none hidden lg:block"></div>
        </section>

        <!-- HORIZONTAL LOGISTICS SEARCH INTERACTION -->
        <section class="px-6 md:px-12 max-w-7xl mx-auto py-12 relative z-20">
            <div class="glass-card rounded-xl p-6 md:p-8 neon-shadow border border-neonCyan/20">
                <form id="search-logistics-form" onsubmit="event.preventDefault(); triggerSearchQuery();" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-end">
                    
                    <!-- Location Pickup -->
                    <div class="space-y-2">
                        <label class="block text-[10px] uppercase tracking-widest text-gray-400 font-bold">Atelier Airfield</label>
                        <div class="relative">
                            <i class="fa-solid fa-plane-departure absolute left-4 top-1/2 -translate-y-1/2 text-neonCyan"></i>
                            <select id="logistics-pickup" required class="w-full bg-obsidian border border-white/10 rounded p-3.5 pl-11 text-xs text-white uppercase tracking-wider focus:border-neonCyan focus:outline-none">
                                <option value="Monaco Heliport">Monaco Atelier (Heliport MC)</option>
                                <option value="Geneva Terminal">Geneva Executive Airfield (GVA)</option>
                                <option value="Nice Runway">Nice Runway Terminal (NCE)</option>
                                <option value="Ibiza Harbor">Ibiza Harbor Lounge (IBZ)</option>
                            </select>
                        </div>
                    </div>

                    <!-- Date Pickup -->
                    <div class="space-y-2">
                        <label class="block text-[10px] uppercase tracking-widest text-gray-400 font-bold">Commence Date</label>
                        <div class="relative">
                            <i class="fa-solid fa-calendar-days absolute left-4 top-1/2 -translate-y-1/2 text-neonCyan"></i>
                            <input type="date" id="logistics-date-start" required class="w-full bg-obsidian border border-white/10 rounded p-3 text-xs text-white uppercase tracking-wider focus:border-neonCyan focus:outline-none pl-11">
                        </div>
                    </div>

                    <!-- Date Dropoff -->
                    <div class="space-y-2">
                        <label class="block text-[10px] uppercase tracking-widest text-gray-400 font-bold">Terminate Date</label>
                        <div class="relative">
                            <i class="fa-solid fa-calendar-xmark absolute left-4 top-1/2 -translate-y-1/2 text-neonCyan"></i>
                            <input type="date" id="logistics-date-end" required class="w-full bg-obsidian border border-white/10 rounded p-3 text-xs text-white uppercase tracking-wider focus:border-neonCyan focus:outline-none pl-11">
                        </div>
                    </div>

                    <!-- Submit -->
                    <div>
                        <button type="submit" class="w-full py-4 bg-neonCyan hover:bg-white text-obsidian font-black text-xs uppercase tracking-widest rounded transition duration-300 flex items-center justify-center space-x-2">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <span>Scan Available Fleet</span>
                        </button>
                    </div>
                </form>
            </div>
        </section>


        <!-- FEATURED FLEET CATALOG -->
        <section id="fleet" class="py-24 px-6 md:px-12 max-w-7xl mx-auto relative z-20">
            
            <div class="flex flex-col lg:flex-row items-baseline justify-between gap-6 mb-16">
                <div class="space-y-3">
                    <span class="text-xs uppercase tracking-[0.3em] text-neonCyan font-bold">Atelier Catalog</span>
                    <h2 class="font-display text-4xl md:text-5xl font-black text-white uppercase">The Veloce Stable</h2>
                    <p class="text-gray-400 text-sm max-w-lg">
                        Sort our operational high-performance units. Filter dynamically by performance profile and power mechanics.
                    </p>
                </div>

                <!-- Filter Row -->
                <div id="fleet-filter-bar" class="flex flex-wrap gap-2 text-[10px] uppercase tracking-widest font-bold">
                    <button onclick="filterFleet('all')" id="btn-fleet-all" class="px-5 py-2.5 bg-neonCyan text-obsidian rounded transition">All</button>
                    <button onclick="filterFleet('Hyper')" id="btn-fleet-Hyper" class="px-5 py-2.5 border border-white/10 hover:border-neonCyan text-gray-400 hover:text-white rounded transition">Hypercar</button>
                    <button onclick="filterFleet('Sport')" id="btn-fleet-Sport" class="px-5 py-2.5 border border-white/10 hover:border-neonCyan text-gray-400 hover:text-white rounded transition">Motorsport</button>
                    <button onclick="filterFleet('EV')" id="btn-fleet-EV" class="px-5 py-2.5 border border-white/10 hover:border-neonCyan text-gray-400 hover:text-white rounded transition">Electric</button>
                    <button onclick="filterFleet('SuperSUV')" id="btn-fleet-SuperSUV" class="px-5 py-2.5 border border-white/10 hover:border-neonCyan text-gray-400 hover:text-white rounded transition">Ultimate SUV</button>
                </div>
            </div>

            <!-- Fleet Grid -->
            <div id="fleet-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                
                <!-- Vehicle Card 1 (Ferrari) -->
                <div class="fleet-card group bg-carbon/80 border border-white/5 rounded-xl overflow-hidden hover:border-neonCyan/30 transition-all duration-300" data-category="Hyper" data-price="2400" data-name="Apex GT F90">
