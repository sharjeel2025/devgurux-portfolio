                document.getElementById('step-verify').classList.remove('hidden');

                // populate final receipt coordinates
                wizardState.pickup = document.getElementById('wiz-pickup').value;
                wizardState.date = document.getElementById('wiz-date').value;

                document.getElementById('sum-car').innerText = wizardState.carName;
                document.getElementById('sum-pickup').innerText = wizardState.pickup;
