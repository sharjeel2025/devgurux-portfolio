        function requestMembershipInfo(tierName) {
            showToast(`Information pack queued for ${tierName}. Contact concierge.`);
        }

        function goToWizardStep(step) {
            wizardState.step = step;

            // indicator step update
            const stages = {
                1: document.getElementById('wizard-s1'),
                2: document.getElementById('wizard-s2'),
                3: document.getElementById('wizard-s3')
            };

            for (let s in stages) {
                if (s == step) {
                    stages[s].className = 'text-neonCyan font-bold';
                } else {
                    stages[s].className = 'text-gray-600';
