    <!-- JAVASCRIPT ANIMATIONS & INTERACTIVE LOGIC -->
    <script>
        // DOM ELEMENTS NAVIGATION
        const mobileToggle = document.getElementById('mobile-toggle');
        const mobileDrawer = document.getElementById('mobile-drawer');
        const preloader = document.getElementById('preloader');

        // Preloader transition completion
        window.addEventListener('load', () => {
            setTimeout(() => {
                preloader.classList.add('opacity-0');
                setTimeout(() => {
                    preloader.style.display = 'none';
                }, 1000);
            }, 1000);
        });

        // Mobile Drawer Controller
        mobileToggle.addEventListener('click', toggleDrawer);
        function toggleDrawer() {
            mobileDrawer.classList.toggle('hidden');
            const icon = mobileToggle.querySelector('i');
            if (mobileDrawer.classList.contains('hidden')) {
                icon.className = 'fa-solid fa-bars-staggered text-xl';
            } else {
                icon.className = 'fa-solid fa-xmark text-xl';
            }
        }

        // Close drawer on clicking options
        document.querySelectorAll('.drawer-link').forEach(link => {
            link.addEventListener('click', () => {
                mobileDrawer.classList.add('hidden');
                mobileToggle.querySelector('i').className = 'fa-solid fa-bars-staggered text-xl';
            });
        });


        // PORTFOLIO FILTERING BEHAVIORS
        function filterPortfolio(category) {
            // style action button
            document.querySelectorAll('#portfolio-filter-bar button').forEach(btn => {
                if (btn.id === `btn-port-${category}`) {
                    btn.className = 'px-5 py-2.5 bg-hazardOrange text-steelDark rounded transition';
                } else {
                    btn.className = 'px-5 py-2.5 border border-white/10 hover:border-hazardOrange text-gray-400 hover:text-white rounded transition';
                }
            });

            // handle grid filtering
            document.querySelectorAll('.portfolio-card').forEach(card => {
                if (category === 'all' || card.getAttribute('data-category') === category) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }


        // TOAST NOTIFICATIONS
        function showToast(message) {
            const toast = document.getElementById('custom-toast');
            const toastMsg = document.getElementById('toast-message');

            toastMsg.innerText = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }


        // ==========================================
        // STRUCTURAL PLANNING ESTIMATOR CALCULATIONS
        // ==========================================
        let estimatorState = {
            sectorPrice: 220,
            steelAdd: 0,
            area: 45000,
            privileges: []
        };

        function calculateStructure() {
            // Get base multiplier from sector
            const sectorSelect = document.getElementById('est-sector');
            const chosenSector = sectorSelect.options[sectorSelect.selectedIndex];
            estimatorState.sectorPrice = parseFloat(chosenSector.getAttribute('data-multiplier'));

            // Get steel structural add-on
            const steelSelect = document.getElementById('est-steel');
            const chosenSteel = steelSelect.options[steelSelect.selectedIndex];
            estimatorState.steelAdd = parseFloat(chosenSteel.getAttribute('data-add'));

            // Area square footage
            const areaValue = document.getElementById('est-area').value;
            estimatorState.area = parseInt(areaValue);
            document.getElementById('est-area-val').innerText = estimatorState.area.toLocaleString();

            renderCostStatement();
        }

        function togglePrivilege(name, price, elementId) {
            const index = estimatorState.privileges.findIndex(item => item.name === name);
            const card = document.getElementById(elementId);
            const statusLabel = document.getElementById(`${elementId}-status`);

            if (index > -1) {
                estimatorState.privileges.splice(index, 1);
                card.classList.remove('border-hazardOrange');
                statusLabel.innerText = 'Add';
                statusLabel.classList.remove('text-hazardOrange');
                statusLabel.classList.add('text-gray-500');
                showToast(`Removed accessory parameter: ${name}`);
            } else {
                estimatorState.privileges.push({ name, price });
                card.classList.add('border-hazardOrange');
                statusLabel.innerText = 'Applied';
                statusLabel.classList.remove('text-gray-500');
                statusLabel.classList.add('text-hazardOrange');
                showToast(`Applied accessory parameter: ${name}`);
            }

            renderCostStatement();
        }

        function renderCostStatement() {
            const appliedContainer = document.getElementById('est-applied-addons');
            const addonsItems = document.getElementById('est-addons-items');

            if (estimatorState.privileges.length === 0) {
                appliedContainer.classList.add('hidden');
            } else {
                appliedContainer.classList.remove('hidden');
                addonsItems.innerHTML = '';
                estimatorState.privileges.forEach(priv => {
                    const div = document.createElement('div');
                    div.className = 'flex justify-between text-xs text-gray-300';
                    div.innerHTML = `<span>${priv.name}</span><span class="text-hazardOrange font-bold">+$${priv.price.toLocaleString()}</span>`;
                    addonsItems.appendChild(div);
                });
            }

            // Calculations formula: (Base price + steel price) * area + privileges total
            let baseCosts = (estimatorState.sectorPrice + estimatorState.steelAdd) * estimatorState.area;
            let privilegesTotal = estimatorState.privileges.reduce((sum, item) => sum + item.price, 0);
            let finalEstimate = baseCosts + privilegesTotal;

            document.getElementById('est-total-cost').innerText = `$${finalEstimate.toLocaleString()}`;
        }

        function bookWithEstimateDetails() {
            const sectorSelect = document.getElementById('est-sector');
            const sectorName = sectorSelect.options[sectorSelect.selectedIndex].value;
            const multiplier = sectorSelect.options[sectorSelect.selectedIndex].getAttribute('data-multiplier');

            openQuoteModal();
            selectWizardSector(sectorName, parseFloat(multiplier));

            document.getElementById('wiz-area').value = estimatorState.area;
            goToWizardStep(2);
        }


        // ==========================================
        // CONVERSATIONAL WIZARD STATES
        // ==========================================
        let wizardState = {
            step: 1,
            sector: 'Commercial',
            basePrice: 220,
            area: 50000,
            steel: 'Structural',
            steelAdd: 0,
            addBim: false,
            addFasttrack: false
        };

        function openQuoteModal() {
            document.getElementById('quote-modal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            goToWizardStep(1);
        }

        function closeQuoteModal() {
            document.getElementById('quote-modal').classList.add('hidden');
            document.body.style.overflow = 'auto';

            document.getElementById('step-success').classList.add('hidden');
            document.getElementById('step-sector').classList.remove('hidden');
            document.getElementById('step-materials').classList.add('hidden');
            document.getElementById('step-verify').classList.add('hidden');
        }

        function selectWizardSector(name, multiplier) {
            wizardState.sector = name;
            wizardState.basePrice = multiplier;
            const radios = document.getElementsByName('wiz-srv');
            radios.forEach(r => {
                if (r.value === name) r.checked = true;
            });
        }

        function goToWizardStep(step) {
            wizardState.step = step;

            const stages = {
                1: document.getElementById('wiz-s1'),
                2: document.getElementById('wiz-s2'),
                3: document.getElementById('wiz-s3')
            };

            for (let s in stages) {
                if (s == step) {
                    stages[s].className = 'text-hazardOrange font-bold';
                } else {
                    stages[s].className = 'text-gray-600';
                }
            }

            document.getElementById('step-sector').classList.add('hidden');
            document.getElementById('step-materials').classList.add('hidden');
            document.getElementById('step-verify').classList.add('hidden');

            if (step === 1) {
                document.getElementById('step-sector').classList.remove('hidden');
            } else if (step === 2) {
                document.getElementById('step-materials').classList.remove('hidden');
            } else if (step === 3) {
                document.getElementById('step-verify').classList.remove('hidden');

                // capture inputs
                wizardState.area = parseInt(document.getElementById('wiz-area').value) || 5000;
                
                const steelSelect = document.getElementById('wiz-steel-pref');
                const steelOption = steelSelect.options[steelSelect.selectedIndex];
                wizardState.steel = steelOption.text;
                wizardState.steelAdd = parseFloat(steelOption.getAttribute('data-add'));

                wizardState.addBim = document.getElementById('wiz-add-bim').checked;
                wizardState.addFasttrack = document.getElementById('wiz-add-fasttrack').checked;

                // estimate formulation inside modal summary
                let baseCosts = (wizardState.basePrice + wizardState.steelAdd) * wizardState.area;
                let addBimCost = wizardState.addBim ? 15000 : 0;
                let addFasttrackCost = wizardState.addFasttrack ? 45000 : 0;
                let totalWizardCosts = baseCosts + addBimCost + addFasttrackCost;

                document.getElementById('sum-sector').innerText = wizardState.sector;
                document.getElementById('sum-area').innerText = `${wizardState.area.toLocaleString()} Sq. Ft.`;
                document.getElementById('sum-steel').innerText = wizardState.steel;
                document.getElementById('sum-total').innerText = `$${totalWizardCosts.toLocaleString()}`;
            }
        }

        function finalizeWizardBooking() {
            const name = document.getElementById('wiz-client-name').value;
            const phone = document.getElementById('wiz-client-phone').value;
            const email = document.getElementById('wiz-client-email').value;

            if (!name || !phone || !email) {
                showToast("Please authenticate identity credentials.");
                return;
            }

            document.getElementById('step-verify').classList.add('hidden');
            document.getElementById('step-success').classList.remove('hidden');
        }


        // ==========================================
        // THREE.JS 3D CINEMATIC CONSTRUCTION SITE ENGINE
        // ==========================================
        let scene, camera, renderer, siteGroup, environmentalDust;
        let ambientLight, directionalLight, sodiumSpotLight, blueKeyLight;

        let isDragging = false;
        let previousMousePosition = { x: 0, y: 0 };
        let dragRotationOffset = { x: 0, y: 0 };
        let targetDragRotationOffset = { x: 0, y: 0 };

        let scrollY = 0;
        let lerpScrollY = 0;

        window.addEventListener('scroll', () => {
            scrollY = window.scrollY;
        });

        function setupInteractiveDrag() {
            const zone = document.getElementById('hero-3d-interactive-zone');
            if (!zone) return;

            zone.addEventListener('mousedown', (e) => {
                isDragging = true;
                previousMousePosition = { x: e.clientX, y: e.clientY };
            });

            window.addEventListener('mouseup', () => {
                isDragging = false;
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                const deltaMove = {
                    x: e.clientX - previousMousePosition.x,
                    y: e.clientY - previousMousePosition.y
                };

                targetDragRotationOffset.y += deltaMove.x * 0.007;
                targetDragRotationOffset.x += deltaMove.y * 0.007;

                previousMousePosition = { x: e.clientX, y: e.clientY };
            });

            zone.addEventListener('touchstart', (e) => {
                isDragging = true;
                const touch = e.touches[0];
                previousMousePosition = { x: touch.clientX, y: touch.clientY };
            }, { passive: true });

            window.addEventListener('touchmove', (e) => {
                if (!isDragging) return;
                const touch = e.touches[0];
                const deltaMove = {
                    x: touch.clientX - previousMousePosition.x,
                    y: touch.clientY - previousMousePosition.y
                };

                targetDragRotationOffset.y += deltaMove.x * 0.007;
                targetDragRotationOffset.x += deltaMove.y * 0.007;

                previousMousePosition = { x: touch.clientX, y: touch.clientY };
            }, { passive: true });

            window.addEventListener('touchend', () => {
                isDragging = false;
            });
        }

        function buildConstructionThreeJS() {
            const viewport = document.getElementById('canvas-viewport');
            const width = window.innerWidth;
            const height = window.innerHeight;

            scene = new THREE.Scene();

            camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 100);
            camera.position.set(0, 4.0, 15.0);

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(width, height);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            viewport.appendChild(renderer.domElement);

            // Group containing all site assemblies
            siteGroup = new THREE.Group();

            // 1. BLUEPRINT GLOWING BOTTOM GRID
            const gridHelper = new THREE.GridHelper(30, 30, 0x0055FF, 0x1F2937);
            gridHelper.position.y = -1.5;
            siteGroup.add(gridHelper);

            // 2. CONCRETE FOUNDATION SLAB
            const slabGeo = new THREE.BoxGeometry(8, 0.4, 8);
            const foundationMat = new THREE.MeshStandardMaterial({
                color: 0x1F2937,
                roughness: 0.9,
                metalness: 0.1
            });
            const slab = new THREE.Mesh(slabGeo, foundationMat);
            slab.position.y = -1.3;
            siteGroup.add(slab);

            // 3. SKYSCRAPER CORE STRUCTURAL COLUMNS (Multiple rising floors)
            const columnGroup = new THREE.Group();
            const columnGeo = new THREE.CylinderGeometry(0.08, 0.08, 3.5, 8);
            const beamGeo = new THREE.BoxGeometry(2.5, 0.08, 0.08);
            const steelMat = new THREE.MeshStandardMaterial({
                color: 0x374151,
                roughness: 0.4,
                metalness: 0.95
            });

            // Create modular floor setup dynamically
            function createStructuralFloor(yOffset, isWireframe = false) {
                const floor = new THREE.Group();
                const currentSteelMat = isWireframe ? 
                    new THREE.MeshBasicMaterial({ color: 0xFF5500, wireframe: true }) : steelMat;

                // 4 corner columns
                const positions = [
                    [-1.2, 1.2], [1.2, 1.2], [-1.2, -1.2], [1.2, -1.2]
                ];

                positions.forEach(pos => {
                    const col = new THREE.Mesh(columnGeo, currentSteelMat);
                    col.position.set(pos[0], 0, pos[1]);
                    floor.add(col);
                });

                // Horizontal girders connecting columns
                const beam1 = new THREE.Mesh(beamGeo, currentSteelMat);
                beam1.position.set(0, 1.75, 1.2);
                const beam2 = beam1.clone();
                beam2.position.z = -1.2;
                
                const beam3 = beam1.clone();
                beam3.rotation.y = Math.PI / 2;
                beam3.position.set(1.2, 1.75, 0);
                const beam4 = beam3.clone();
                beam4.position.x = -1.2;

                floor.add(beam1, beam2, beam3, beam4);
                floor.position.y = yOffset;
                return floor;
            }

            // Stacking 3 dynamic floors
            const floor1 = createStructuralFloor(-1.1);
            const floor2 = createStructuralFloor(2.4);
            const floor3 = createStructuralFloor(5.9, true); // Active orange wireframe building phase at top

            columnGroup.add(floor1, floor2, floor3);
            siteGroup.add(columnGroup);

            // 4. HEAVY CRANE ASSEMBLY
            const craneGroup = new THREE.Group();
            craneGroup.position.set(-3.2, -1.3, -2.5);

            // Crane mast tower
            const mastGeo = new THREE.CylinderGeometry(0.12, 0.12, 9.0, 8);
            const mast = new THREE.Mesh(mastGeo, steelMat);
            mast.position.y = 4.5;
            craneGroup.add(mast);

            // Crane horizontal jib/boom assembly
            const jibGroup = new THREE.Group();
            jibGroup.position.y = 9.0;

            const armGeo = new THREE.BoxGeometry(0.15, 0.15, 7.5);
            const arm = new THREE.Mesh(armGeo, new THREE.MeshStandardMaterial({
                color: 0xFF5500, // Vibrant Construction Crane Orange
                roughness: 0.5,
                metalness: 0.8
            }));
            arm.position.z = 2.0; // Extend arm forwards
            jibGroup.add(arm);

            // Crane counter jib block
            const counterBlockGeo = new THREE.BoxGeometry(0.4, 0.4, 0.8);
            const counterBlock = new THREE.Mesh(counterBlockGeo, foundationMat);
            counterBlock.position.z = -1.5;
            jibGroup.add(counterBlock);

            craneGroup.add(jibGroup);
            siteGroup.add(craneGroup);

            // Add complete site assembly to environment stage
            scene.add(siteGroup);

            // 5. ENVIRONMENTAL PARTICLES SYSTEM (Simulating active construction site dust / sunbeams)
            const particlesCount = 280;
            const particleGeo = new THREE.BufferGeometry();
            const positionsArray = new Float32Array(particlesCount * 3);

            for (let i = 0; i < particlesCount * 3; i += 3) {
                positionsArray[i] = (Math.random() - 0.5) * 35;     // X scatter
                positionsArray[i + 1] = (Math.random() - 0.5) * 20; // Y scatter
                positionsArray[i + 2] = (Math.random() - 0.5) * 30; // Z scatter
            }

            particleGeo.setAttribute('position', new THREE.BufferAttribute(positionsArray, 3));

            const particleMaterial = new THREE.PointsMaterial({
                size: 0.08,
                color: 0xFF5500, // Warm sodium industrial particles
                transparent: true,
                opacity: 0.45,
                blending: THREE.AdditiveBlending
            });

            environmentalDust = new THREE.Points(particleGeo, particleMaterial);
            scene.add(environmentalDust);


            // STUDIO SODIUM LIGHTING STAGE
            ambientLight = new THREE.AmbientLight(0xffffff, 0.3); // Baseline lighting
            scene.add(ambientLight);

            // Heavy direct sunlight
            directionalLight = new THREE.DirectionalLight(0xffffff, 2.5);
            directionalLight.position.set(10, 20, 10);
            scene.add(directionalLight);

            // High intensity industrial warning sodium spotlight
            sodiumSpotLight = new THREE.SpotLight(0xFF5500, 4.5, 30, Math.PI / 4, 0.5, 1);
            sodiumSpotLight.position.set(-5, 12, 5);
            scene.add(sodiumSpotLight);

            // Cool blueprint blue fill light opposite to sodium
            blueKeyLight = new THREE.DirectionalLight(0x0055FF, 2.0);
            blueKeyLight.position.set(8, -5, -8);
            scene.add(blueKeyLight);

            window.addEventListener('resize', onWindowResize);
            applyResponsiveFit();
            setupInteractiveDrag();

            // Fire animation clock
            animateCinematic();
        }

        // SCALING CORRECTIONS FOR ALL SCREENS
        function applyResponsiveFit() {
            if (!siteGroup) return;
            const width = window.innerWidth;
            
            if (width < 640) {
                siteGroup.scale.set(0.6, 0.6, 0.6);
            } else if (width < 1024) {
                siteGroup.scale.set(0.85, 0.85, 0.85);
            } else {
                siteGroup.scale.set(1.15, 1.15, 1.15);
            }
        }

        function onWindowResize() {
            const width = window.innerWidth;
            const height = window.innerHeight;

            camera.aspect = width / height;
            camera.updateProjectionMatrix();

            renderer.setSize(width, height);
            applyResponsiveFit();
        }

        // CINEMATIC KINETIC RENDER LOOP
        let animationTimer = 0;
        function animateCinematic() {
            requestAnimationFrame(animateCinematic);
            animationTimer += 0.01;

            // Interpolated Scroll Physics
            lerpScrollY += (scrollY - lerpScrollY) * 0.05;

            const docHeight = document.documentElement.scrollHeight - window.innerHeight || 1;
            const scrollFraction = Math.min(lerpScrollY / docHeight, 1.0);

            // DRAG TENSION DECAY CONTROL
            if (!isDragging) {
                targetDragRotationOffset.x *= 0.95;
                targetDragRotationOffset.y *= 0.95;
            }

            dragRotationOffset.x += (targetDragRotationOffset.x - dragRotationOffset.x) * 0.15;
            dragRotationOffset.y += (targetDragRotationOffset.y - dragRotationOffset.y) * 0.15;

            // 1. SCROLL-TIED STEEL BUILDING ASSEMBLY
            if (siteGroup) {
                // Skyscraper columns scale upwards as user scrolls down
                const floors = siteGroup.children[2].children; // ColumnGroup containing the 3 floors
                
                // Floor 1 rises immediately
                floors[0].scale.y = Math.min(scrollFraction * 2.5, 1.0);
                // Floor 2 rises at mid-scroll
                floors[1].scale.y = Math.min(Math.max((scrollFraction - 0.25) * 2.5, 0.0), 1.0);
                // Floor 3 (orange blueprint core) rises at late scroll
                floors[2].scale.y = Math.min(Math.max((scrollFraction - 0.5) * 2.5, 0.0), 1.0);

                // 2. CRANE JIB ROTATION
                // Crane rotating jib arm rotates dynamically
                const craneJib = siteGroup.children[3].children[1]; // Jib group inside heavy crane
                craneJib.rotation.y = (Math.sin(animationTimer * 0.5) * 0.4) + (scrollFraction * Math.PI);
            }

            // 3. CAMERA CHOREOGRAPHY THROUGHOUT ENTIRE SCROLL
            const isMobile = window.innerWidth < 768;

            if (siteGroup) {
                if (isMobile) {
                    siteGroup.position.x = 0;
                    siteGroup.position.y = -1.5 + (scrollFraction * 1.5);
                    siteGroup.position.z = -1.0;

                    siteGroup.rotation.x = dragRotationOffset.x;
                    siteGroup.rotation.y = dragRotationOffset.y + (scrollFraction * Math.PI);
                } else {
                    // Desktop path: Starts on the middle-right of hero section, glides left/zooms as user scrolls
                    siteGroup.position.x = 2.4 - (scrollFraction * 5.0);
                    siteGroup.position.y = -0.5 + (scrollFraction * 1.2);
                    siteGroup.position.z = 0.0 + (scrollFraction * 2.0);

                    // Sweeping rotation & parallax drift
                    siteGroup.rotation.x = dragRotationOffset.x + (Math.sin(animationTimer * 0.2) * 0.05);
                    siteGroup.rotation.y = dragRotationOffset.y + (animationTimer * 0.03 + (scrollFraction * Math.PI * 1.2));
                }
            }

            // 4. ACTIVE ENVIRO-PARTICLE KINETICS
            if (environmentalDust) {
                const positions = environmentalDust.geometry.attributes.position.array;
                for (let i = 0; i < positions.length; i += 3) {
                    positions[i + 1] -= 0.02 + (scrollFraction * 0.05); // Particles drift downward
                    if (positions[i + 1] < -10) {
                        positions[i + 1] = 10; // loop back to top
                    }
                }
                environmentalDust.geometry.attributes.position.needsUpdate = true;
            }

            renderer.render(scene, camera);
        }

        // Initialize 3D Engine on load
        window.onload = function () {
            buildConstructionThreeJS();
            calculateStructure(); // Fire baseline estimator cost logic
        }
    </script>

</body>
