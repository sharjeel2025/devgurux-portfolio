<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NEXUS ELITE · Forge Your Legacy</title>

    <!-- Google Fonts: Outfit + Space Grotesk (unique combo) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Three.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js">
    </script>

    <style>
        /* ============================================
                   ROOT VARIABLES — UNIQUE DARK THEME
                   ============================================ */
        :root {
            --bg-deep: #08080e;
            --bg-surface: #0e0e1a;
            --bg-card: #131323;
            --bg-card-hover: #1a1a30;
            --text-primary: #f0f4ff;
            --text-secondary: #b8c4e0;
            --text-muted: #6a7a9a;

            --cyan-bright: #00d4ff;
            --cyan-glow: rgba(0, 212, 255, 0.25);
            --purple-deep: #7c3aed;
            --purple-glow: rgba(124, 58, 237, 0.25);
            --gold-amber: #f59e0b;
            --gold-glow: rgba(245, 158, 11, 0.2);

            --gradient-prime: linear-gradient(135deg, #00d4ff 0%, #7c3aed 60%, #f59e0b 100%);
            --gradient-card: linear-gradient(145deg, rgba(0, 212, 255, 0.08), rgba(124, 58, 237, 0.05));

            --radius-card: 20px;
            --radius-btn: 60px;
            --shadow-elevated: 0 20px 60px rgba(0, 0, 0, 0.7);
        }

        /* ============================================
                   RESET & BASE
                   ============================================ */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg-deep);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-deep);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--cyan-bright);
            border-radius: 12px;
            box-shadow: 0 0 20px var(--cyan-glow);
        }

        /* selection */
        ::selection {
            background: var(--cyan-bright);
            color: #08080e;
        }

        /* ============================================
                   THREE.JS CANVAS (background)
                   ============================================ */
        #webgl-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        /* ============================================
                   UTILITY CLASSES
                   ============================================ */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .font-display {
            font-family: 'Space Grotesk', 'Outfit', sans-serif;
        }

        .text-gradient {
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .glass-panel {
            background: rgba(14, 14, 26, 0.55);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(255, 255, 255, 0.04);
        }

        .glass-panel-light {
            background: rgba(19, 19, 35, 0.65);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        /* ============================================
                   PRELOADER
                   ============================================ */
        #preloader {
            position: fixed;
            inset: 0;
            z-index: 999;
            background: var(--bg-deep);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.9s ease, visibility 0.9s ease;
        }
        #preloader.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        .preloader-ring {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            border: 3px solid transparent;
            border-top-color: var(--cyan-bright);
            border-right-color: var(--purple-deep);
            animation: spin 1.2s cubic-bezier(0.6, 0.0, 0.4, 1.0) infinite;
            position: relative;
        }
        .preloader-ring::after {
            content: '';
            position: absolute;
            inset: 6px;
            border-radius: 50%;
            border: 3px solid transparent;
            border-bottom-color: var(--gold-amber);
            border-left-color: var(--cyan-bright);
            animation: spin 0.8s cubic-bezier(0.6, 0.0, 0.4, 1.0) infinite reverse;
        }
        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .preloader-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            margin-top: 28px;
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ============================================
                   NAVBAR
                   ============================================ */
        #navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 100;
            padding: 20px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.4s ease;
            border-bottom: 1px solid transparent;
        }
        #navbar.scrolled {
            background: rgba(8, 8, 14, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom-color: rgba(255, 255, 255, 0.04);
            padding: 14px 32px;
        }

        .brand {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            text-decoration: none;
            color: #fff;
        }
        .brand span {
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 32px;
            list-style: none;
        }
        .nav-links a {
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.3s ease;
            position: relative;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--gradient-prime);
            transition: width 0.35s ease;
        }
        .nav-links a:hover {
            color: #fff;
        }
        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-cta {
            padding: 10px 28px;
            border-radius: var(--radius-btn);
            background: var(--gradient-prime);
            color: #08080e !important;
            font-weight: 700 !important;
            font-size: 0.7rem !important;
            letter-spacing: 0.08em !important;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.15);
            text-decoration: none !important;
        }
        .nav-cta::after {
            display: none !important;
        }
        .nav-cta:hover {
            transform: scale(1.04);
            box-shadow: 0 0 50px rgba(0, 212, 255, 0.3);
        }

        /* Mobile menu toggle */
        .menu-toggle {
            display: none;
            background: none;
            border: none;
            color: #fff;
            font-size: 1.6rem;
            cursor: pointer;
            padding: 4px;
        }

        .mobile-nav {
            position: fixed;
            inset: 0;
            z-index: 99;
            background: rgba(8, 8, 14, 0.97);
            backdrop-filter: blur(24px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 32px;
            transform: translateX(100%);
            transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            padding: 40px;
        }
        .mobile-nav.open {
            transform: translateX(0);
        }
        .mobile-nav a {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .mobile-nav a:hover {
            color: #fff;
        }
        .mobile-nav .nav-cta {
            font-size: 0.9rem !important;
        }

        /* ============================================
                   HERO
                   ============================================ */
        #hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 120px 24px 80px;
            text-align: center;
            z-index: 1;
        }

        #hero .bg-glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            pointer-events: none;
            z-index: 0;
            opacity: 0.3;
            animation: floatGlow 18s ease-in-out infinite alternate;
        }
        #hero .bg-glow--1 {
            width: 600px;
            height: 600px;
            background: var(--cyan-bright);
            top: -200px;
            right: -100px;
            opacity: 0.12;
        }
        #hero .bg-glow--2 {
            width: 500px;
            height: 500px;
            background: var(--purple-deep);
            bottom: -200px;
            left: -100px;
            opacity: 0.10;
            animation-delay: -6s;
        }
        #hero .bg-glow--3 {
            width: 400px;
            height: 400px;
            background: var(--gold-amber);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            opacity: 0.06;
            animation-delay: -12s;
        }

        @keyframes floatGlow {
            0% {
                transform: translate(0, 0) scale(1);
            }
            100% {
                transform: translate(40px, -30px) scale(1.2);
            }
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 900px;
        }

        .hero-badge {
            display: inline-block;
            padding: 6px 22px;
            border-radius: 60px;
            background: rgba(0, 212, 255, 0.06);
            border: 1px solid rgba(0, 212, 255, 0.12);
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--cyan-bright);
            margin-bottom: 24px;
        }
        .hero-badge i {
            margin-right: 8px;
        }

        .hero-title {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: clamp(3rem, 10vw, 6rem);
            line-height: 1.04;
            letter-spacing: -0.03em;
            margin-bottom: 20px;
        }
        .hero-title .line-1 {
            display: block;
            color: #fff;
        }
        .hero-title .line-2 {
            display: block;
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-sub {
            font-size: clamp(1rem, 1.4vw, 1.25rem);
            color: var(--text-secondary);
            max-width: 640px;
            margin: 0 auto 36px;
            font-weight: 300;
            line-height: 1.8;
        }

        .hero-buttons {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 16px;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 16px 40px;
            border-radius: var(--radius-btn);
            background: var(--gradient-prime);
            color: #08080e;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 0.04em;
            border: none;
            cursor: pointer;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            box-shadow: 0 0 40px rgba(0, 212, 255, 0.15);
            text-decoration: none;
        }
        .btn-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 0 60px rgba(0, 212, 255, 0.3);
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 16px 40px;
            border-radius: var(--radius-btn);
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.12);
            color: #fff;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.04em;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(255, 255, 255, 0.25);
            transform: translateY(-3px);
        }

        /* scroll indicator */
        .scroll-indicator {
            position: absolute;
            bottom: 32px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            opacity: 0.5;
            animation: bounceDown 2.4s ease-in-out infinite;
        }
        .scroll-indicator span {
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--text-muted);
        }
        .scroll-indicator .line {
            width: 1px;
            height: 40px;
            background: linear-gradient(to bottom, var(--cyan-bright), transparent);
        }
        @keyframes bounceDown {
            0%,
            100% {
                transform: translateX(-50%) translateY(0);
            }
            50% {
                transform: translateX(-50%) translateY(8px);
            }
        }

        /* ============================================
                   SECTIONS — shared
                   ============================================ */
        section {
            position: relative;
            z-index: 1;
            padding: 100px 0;
        }

        .section-label {
            display: inline-block;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--cyan-bright);
            margin-bottom: 12px;
        }

        .section-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(2.2rem, 5vw, 3.6rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1.1;
            margin-bottom: 16px;
        }
        .section-title .highlight {
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .section-desc {
            color: var(--text-secondary);
            font-size: 1.05rem;
            max-width: 560px;
            font-weight: 300;
            line-height: 1.7;
        }

        /* ============================================
                   ABOUT / PHILOSOPHY
                   ============================================ */
        #about {
            padding-top: 60px;
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }

        .about-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 32px;
            padding-top: 32px;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
        }
        .about-stat h4 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 2.4rem;
            font-weight: 700;
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .about-stat p {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .about-cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .about-card {
            padding: 28px 24px;
            border-radius: var(--radius-card);
            background: var(--gradient-card);
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.4s ease;
            cursor: default;
        }
        .about-card:hover {
            transform: translateY(-6px);
            border-color: rgba(0, 212, 255, 0.15);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
        }
        .about-card .icon {
            font-size: 1.8rem;
            margin-bottom: 14px;
            display: inline-block;
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .about-card h4 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 6px;
        }
        .about-card p {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 300;
        }

        /* ============================================
                   PROGRAMS
                   ============================================ */
        #programs {
            background: var(--bg-surface);
            border-top: 1px solid rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

        .programs-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-top: 48px;
        }

        .program-card {
            position: relative;
            border-radius: var(--radius-card);
            overflow: hidden;
            background: var(--bg-card);
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            height: 360px;
            cursor: pointer;
            group: true;
        }
        .program-card:hover {
            transform: translateY(-10px) scale(1.02);
            border-color: rgba(0, 212, 255, 0.15);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(0, 212, 255, 0.04);
        }

        .program-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s ease;
            filter: grayscale(0.6) brightness(0.5);
        }
        .program-card:hover img {
            transform: scale(1.08);
            filter: grayscale(0.2) brightness(0.6);
        }

        .program-card .overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(8, 8, 14, 0.9) 0%, transparent 60%);
            padding: 28px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            transition: all 0.4s ease;
        }
        .program-card .overlay .tag {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--cyan-bright);
            margin-bottom: 6px;
        }
        .program-card .overlay h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .program-card .overlay p {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 300;
            opacity: 0;
            transform: translateY(12px);
            transition: all 0.4s ease 0.05s;
            max-height: 0;
            overflow: hidden;
        }
        .program-card:hover .overlay p {
            opacity: 1;
            transform: translateY(0);
            max-height: 80px;
            margin-top: 8px;
        }
        .program-card .overlay .btn-link {
            display: inline-block;
            margin-top: 14px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #fff;
            text-decoration: none;
            border-bottom: 2px solid var(--cyan-bright);
            padding-bottom: 2px;
            opacity: 0;
            transform: translateX(-8px);
            transition: all 0.4s ease 0.1s;
        }
        .program-card:hover .overlay .btn-link {
            opacity: 1;
            transform: translateX(0);
        }
        .program-card .overlay .btn-link:hover {
            color: var(--cyan-bright);
        }

        /* ============================================
                   MEMBERSHIPS
                   ============================================ */
        .membership-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
            margin-top: 48px;
        }

        .membership-card {
            border-radius: var(--radius-card);
            padding: 36px 32px 40px;
            background: var(--bg-card);
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.4s ease;
            position: relative;
            display: flex;
            flex-direction: column;
        }
        .membership-card:hover {
            transform: translateY(-8px);
            border-color: rgba(0, 212, 255, 0.1);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }
        .membership-card.popular {
            border: 2px solid transparent;
            background: var(--gradient-card);
            border-image: var(--gradient-prime);
            border-image-slice: 1;
            background-origin: border-box;
            background-clip: padding-box;
            transform: scale(1.04);
        }
        .membership-card.popular:hover {
            transform: scale(1.06) translateY(-8px);
        }
        .membership-card .badge {
            position: absolute;
            top: -10px;
            left: 50%;
            transform: translateX(-50%);
            padding: 4px 20px;
            border-radius: 40px;
            background: var(--gradient-prime);
            color: #08080e;
            font-size: 0.55rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }
        .membership-card h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .membership-card .price {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 2.8rem;
            font-weight: 700;
            margin: 16px 0 8px;
        }
        .membership-card .price span {
            font-size: 1rem;
            font-weight: 400;
            color: var(--text-muted);
        }
        .membership-card .price .currency {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--cyan-bright);
        }
        .membership-card ul {
            list-style: none;
            margin: 20px 0 32px;
            flex: 1;
        }
        .membership-card ul li {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 0;
            font-size: 0.9rem;
            color: var(--text-secondary);
            font-weight: 300;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }
        .membership-card ul li:last-child {
            border-bottom: none;
        }
        .membership-card ul li i {
