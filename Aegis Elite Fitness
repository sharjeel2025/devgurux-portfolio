    <script>
        // --- UI Interactions ---
        const preloader = document.getElementById('preloader');
        const loaderBar = document.getElementById('loader-bar');
        
        window.addEventListener('load', () => {
            loaderBar.style.width = '100%';
            setTimeout(() => {
                preloader.classList.add('opacity-0');
                setTimeout(() => {
                    preloader.style.display = 'none';
                    init3DScene(); // Initialize heavy 3D after preloader finishes
                }, 1000);
            }, 600);
        });

        // Mobile Menu
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        let menuOpen = false;

        mobileBtn.addEventListener('click', () => {
            menuOpen = !menuOpen;
            if (menuOpen) {
                mobileMenu.classList.remove('translate-x-full');
                mobileBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
            } else {
                closeMobileMenu();
            }
        });

        function closeMobileMenu() {
            menuOpen = false;
            mobileMenu.classList.add('translate-x-full');
            mobileBtn.innerHTML = '<i class="fa-solid fa-bars"></i>';
        }

        document.querySelectorAll('.mobile-link').forEach(link => {
            link.addEventListener('click', closeMobileMenu);
        });

        // Navbar blur on scroll
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                navbar.classList.add('bg-obsidian/80', 'backdrop-blur-md', 'border-white/10');
                navbar.classList.remove('py-6', 'border-transparent');
                navbar.classList.add('py-4');
            } else {
                navbar.classList.remove('bg-obsidian/80', 'backdrop-blur-md', 'border-white/10');
                navbar.classList.add('py-6', 'border-transparent');
                navbar.classList.remove('py-4');
            }
        });

        // Modal Logic
        const modal = document.getElementById('booking-modal');
        const modalContent = document.getElementById('modal-content');
        const form = document.getElementById('lead-form');
        const successMsg = document.getElementById('success-msg');

        function openModal() {
            modal.classList.remove('hidden');
            // small delay for transition
            setTimeout(() => {
                modalContent.classList.remove('scale-95', 'opacity-0');
                modalContent.classList.add('scale-100', 'opacity-100');
            }, 10);
            document.body.style.overflow = 'hidden';
            
            // Reset form state
            form.reset();
            form.classList.remove('hidden');
            successMsg.classList.add('hidden');
        }

        function closeModal() {
            modalContent.classList.remove('scale-100', 'opacity-100');
            modalContent.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }, 300);
        }

        function handleFormSubmit(e) {
            e.preventDefault();
            form.classList.add('hidden');
            successMsg.classList.remove('hidden');
            showToast("Lead captured successfully.");
        }

        // Custom Toast Logic
        function showToast(msg) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-text').innerText = msg;
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // --- THREE.JS PROCEDURAL 3D ENVIRONMENT ---
        let scene, camera, renderer;
        let platesGroup, particleSystem, energyCore;
        
        let targetScrollY = 0;
        let currentScrollY = 0;
        
        window.addEventListener('scroll', () => {
            targetScrollY = window.scrollY;
        });

        function init3DScene() {
            const canvasContainer = document.getElementById('webgl-canvas');
            const width = window.innerWidth;
            const height = window.innerHeight;

            // 1. Scene Setup
            scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x070707, 0.02);

            // 2. Camera Setup
            camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
            camera.position.set(0, 0, 25);

            // 3. Renderer Setup
            renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            renderer.setSize(width, height);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 1.2;
            canvasContainer.appendChild(renderer.domElement);

            // 4. Materials
            const metalMaterial = new THREE.MeshPhysicalMaterial({
                color: 0x222222,
                metalness: 0.9,
                roughness: 0.4,
                clearcoat: 0.8,
                clearcoatRoughness: 0.2,
                wireframe: false
            });

            const neonMaterial = new THREE.MeshBasicMaterial({
                color: 0xFF2A00,
                wireframe: true,
                transparent: true,
                opacity: 0.4
            });

            // 5. Build Bumper Plates (Flattened Torus Geometry)
            platesGroup = new THREE.Group();
            const plateCount = 8;
            const plateGeo = new THREE.TorusGeometry(8, 2, 16, 64);
            // Flatten the torus to look like a thick disk/plate with a hole
            plateGeo.scale(1, 1, 0.3);

            for (let i = 0; i < plateCount; i++) {
                const plate = new THREE.Mesh(plateGeo, metalMaterial);
                // Distribute along Z axis
                plate.position.z = -i * 12;
                
                // Add slight random rotation for organic feel
                plate.rotation.x = Math.random() * 0.2 - 0.1;
                plate.rotation.y = Math.random() * 0.2 - 0.1;
                
                // Add a glowing inner ring to some plates
                if (i % 2 === 0) {
                    const innerRingGeo = new THREE.TorusGeometry(5.8, 0.1, 8, 32);
                    const innerRing = new THREE.Mesh(innerRingGeo, new THREE.MeshBasicMaterial({color: 0xFF2A00}));
                    innerRing.position.z = plate.position.z;
                    platesGroup.add(innerRing);
                }

                platesGroup.add(plate);
            }
            scene.add(platesGroup);

            // 6. Build Central Energy Core
            const coreGeo = new THREE.IcosahedronGeometry(2, 2);
            energyCore = new THREE.Mesh(coreGeo, neonMaterial);
            energyCore.position.z = -((plateCount - 1) * 12) / 2; // Center of the tunnel
            scene.add(energyCore);

            // 7. Build Energy Particle Vortex
            const particleCount = 1500;
            const particleGeo = new THREE.BufferGeometry();
            const particlePos = new Float32Array(particleCount * 3);
            const particleColors = new Float32Array(particleCount * 3);
            
            const color1 = new THREE.Color(0xFF2A00); // Crimson
            const color2 = new THREE.Color(0x8892B0); // Steel
            
            for(let i = 0; i < particleCount * 3; i += 3) {
                // Cylindrical distribution
                const radius = 3 + Math.random() * 8;
                const theta = Math.random() * Math.PI * 2;
                const z = (Math.random() - 0.5) * 100;

                particlePos[i] = Math.cos(theta) * radius;     // x
                particlePos[i+1] = Math.sin(theta) * radius;   // y
                particlePos[i+2] = z;                          // z

                // Interpolate colors based on radius
                const mixRatio = Math.random();
                const mixedColor = color1.clone().lerp(color2, mixRatio);
                particleColors[i] = mixedColor.r;
                particleColors[i+1] = mixedColor.g;
                particleColors[i+2] = mixedColor.b;
            }

            particleGeo.setAttribute('position', new THREE.BufferAttribute(particlePos, 3));
            particleGeo.setAttribute('color', new THREE.BufferAttribute(particleColors, 3));

            const particleMat = new THREE.PointsMaterial({
                size: 0.15,
                vertexColors: true,
                transparent: true,
                opacity: 0.8,
                blending: THREE.AdditiveBlending
            });

            particleSystem = new THREE.Points(particleGeo, particleMat);
            scene.add(particleSystem);

            // 8. Lighting Rig
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
            scene.add(ambientLight);

            const redPointLight = new THREE.PointLight(0xFF2A00, 5, 50);
            redPointLight.position.copy(energyCore.position);
            scene.add(redPointLight);

            const directionalLight = new THREE.DirectionalLight(0xffffff, 2);
            directionalLight.position.set(10, 20, 10);
            scene.add(directionalLight);

            // Resize Handler
            window.addEventListener('resize', onWindowResize);

            // Start Animation Loop
            animate();
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const time = clock.getElapsedTime();

            // Smooth scroll interpolation (Lerp)
            currentScrollY += (targetScrollY - currentScrollY) * 0.05;
            
            // Calculate scroll progress (0 to 1 based on document height)
            const docHeight = document.documentElement.scrollHeight - window.innerHeight || 1;
            const scrollProgress = currentScrollY / docHeight;

            // 1. Camera Animation (Fly through the plates based on scroll)
            // Start at z=25, move deep into the tunnel z=-80
            camera.position.z = 25 - (scrollProgress * 105);
            
            // Add slight camera bobbing
            camera.position.y = Math.sin(time * 0.5) * 1.5;
            camera.position.x = Math.cos(time * 0.3) * 1.0;
            
            // Look slightly ahead of the camera
            camera.lookAt(camera.position.x * 0.5, camera.position.y * 0.5, camera.position.z - 20);

            // 2. Object Animations
            if (platesGroup) {
                // Rotate plates slowly
                platesGroup.children.forEach((child, index) => {
                    child.rotation.z = time * 0.1 * (index % 2 === 0 ? 1 : -1);
                });
            }

            if (energyCore) {
                // Pulse core size and rotate
                const scale = 1 + Math.sin(time * 3) * 0.1;
                energyCore.scale.set(scale, scale, scale);
                energyCore.rotation.x = time * 0.5;
                energyCore.rotation.y = time * 0.7;
            }

            if (particleSystem) {
                // Rotate entire particle vortex
                particleSystem.rotation.z = time * 0.05;
                
                // Animate individual particles falling backward (towards camera)
                const positions = particleSystem.geometry.attributes.position.array;
                for(let i=2; i<positions.length; i+=3) {
                    positions[i] += 0.2 + (scrollProgress * 0.5); // Speed up based on scroll
                    if(positions[i] > 30) {
                        positions[i] = -70; // Reset to back of tunnel
                    }
                }
                particleSystem.geometry.attributes.position.needsUpdate = true;
            }

            // Render Frame
            renderer.render(scene, camera);
        }
    </script>
</body>
</html>
