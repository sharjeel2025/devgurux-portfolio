            gap: 14px;
            margin-top: 16px;
        }
        .coach-card .info .socials a {
            color: var(--text-muted);
            transition: color 0.3s ease;
            font-size: 1.1rem;
        }
        .coach-card .info .socials a:hover {
            color: var(--cyan-bright);
        }

        /* ============================================
                   CTA BANNER
                   ============================================ */
        #cta-banner {
            padding: 80px 0;
            background: var(--bg-deep);
            position: relative;
            overflow: hidden;
        }
        #cta-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: var(--gradient-prime);
            opacity: 0.04;
            pointer-events: none;
        }
        #cta-banner .glow-ring {
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: var(--cyan-bright);
