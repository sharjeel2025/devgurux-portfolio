        }

        /* 3D Canvas fixed background */
        #webgl-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -1;
            pointer-events: none;
        }

        /* Glass and UI utilities */
        .glass-panel {
            background: rgba(18, 18, 18, 0.65);
