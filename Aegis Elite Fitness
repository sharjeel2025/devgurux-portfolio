        .footer-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .footer-col ul a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 300;
            transition: color 0.3s ease;
        }
        .footer-col ul a:hover {
            color: #fff;
        }

        .footer-newsletter p {
            color: var(--text-secondary);
            font-size: 0.85rem;
            font-weight: 300;
            margin-bottom: 14px;
        }
        .footer-newsletter .input-group {
            display: flex;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 60px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.03);
        }
        .footer-newsletter .input-group input {
            flex: 1;
            padding: 12px 20px;
            background: transparent;
            border: none;
            color: #fff;
            font-size: 0.85rem;
            outline: none;
            font-family: 'Outfit', sans-serif;
        }
        .footer-newsletter .input-group input::placeholder {
            color: var(--text-muted);
        }
        .footer-newsletter .input-group button {
            padding: 12px 24px;
            background: var(--gradient-prime);
            border: none;
            color: #08080e;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .footer-newsletter .input-group button:hover {
            filter: brightness(1.1);
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 24px;
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 300;
        }
        .footer-bottom .links {
            display: flex;
            gap: 24px;
        }
        .footer-bottom .links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .footer-bottom .links a:hover {
            color: #fff;
        }

        /* ============================================
                   MODAL
                   ============================================ */
        #modal {
            position: fixed;
            inset: 0;
            z-index: 200;
            background: rgba(8, 8, 14, 0.92);
            backdrop-filter: blur(20px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }
        #modal.open {
            display: flex;
        }

        .modal-box {
            max-width: 480px;
            width: 100%;
            background: var(--bg-card);
            border-radius: var(--radius-card);
            border: 1px solid rgba(255, 255, 255, 0.06);
            padding: 40px 36px 44px;
            position: relative;
            transform: scale(0.95) translateY(20px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }
        #modal.open .modal-box {
            transform: scale(1) translateY(0);
            opacity: 1;
        }

        .modal-box .close {
            position: absolute;
            top: 16px;
            right: 20px;
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.4rem;
            cursor: pointer;
            transition: color 0.3s ease;
        }
        .modal-box .close:hover {
            color: #fff;
        }

        .modal-box .icon-big {
            font-size: 2.4rem;
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
        }
        .modal-box h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .modal-box p {
            color: var(--text-secondary);
            font-weight: 300;
            font-size: 0.9rem;
            margin-bottom: 28px;
        }

        .modal-box form {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        .modal-box form .field {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .modal-box form .field label {
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-muted);
        }
        .modal-box form .field input,
        .modal-box form .field select {
            padding: 12px 16px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: #fff;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            outline: none;
            transition: border-color 0.3s ease;
        }
        .modal-box form .field input:focus,
        .modal-box form .field select:focus {
            border-color: var(--cyan-bright);
        }
        .modal-box form .field select option {
            background: var(--bg-card);
        }
        .modal-box form button[type="submit"] {
            padding: 14px;
            border-radius: var(--radius-btn);
            background: var(--gradient-prime);
            border: none;
            color: #08080e;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 0.04em;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 4px;
        }
        .modal-box form button[type="submit"]:hover {
            box-shadow: 0 0 40px rgba(0, 212, 255, 0.2);
            transform: scale(1.02);
        }

        .modal-box .success-msg {
            display: none;
            text-align: center;
            padding: 20px 0;
        }
        .modal-box .success-msg.show {
            display: block;
        }
        .modal-box .success-msg i {
            font-size: 3.6rem;
            background: var(--gradient-prime);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
        }
        .modal-box .success-msg h4 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.4rem;
            font-weight: 700;
        }
        .modal-box .success-msg p {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 20px;
        }
        .modal-box .success-msg .btn-close-modal {
            padding: 10px 32px;
            border-radius: var(--radius-btn);
            background: var(--gradient-prime);
            border: none;
            color: #08080e;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .modal-box .success-msg .btn-close-modal:hover {
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.2);
        }

        /* ============================================
                   TOAST
                   ============================================ */
        #toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 300;
            padding: 16px 28px;
            border-radius: 16px;
            background: var(--bg-card);
            border: 1px solid rgba(0, 212, 255, 0.1);
            backdrop-filter: blur(16px);
            display: flex;
            align-items: center;
            gap: 14px;
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            pointer-events: none;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }
        #toast.show {
            transform: translateY(0);
            opacity: 1;
            pointer-events: auto;
        }
        #toast i {
            font-size: 1.2rem;
            color: var(--cyan-bright);
        }
        #toast span {
            font-weight: 500;
            font-size: 0.9rem;
        }

        /* ============================================
                   RESPONSIVE
                   ============================================ */
        @media (max-width: 1024px) {
            .about-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            .programs-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .membership-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .membership-card.popular {
                transform: scale(1);
            }
            .membership-card.popular:hover {
                transform: translateY(-8px);
            }
            .coaches-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .footer-grid {
                grid-template-columns: 1fr 1fr;
                gap: 32px;
            }
        }

        @media (max-width: 768px) {
            #navbar {
                padding: 14px 20px;
            }
            #navbar.scrolled {
                padding: 10px 20px;
            }
            .brand {
                font-size: 1.4rem;
            }
            .nav-links {
                display: none;
            }
            .menu-toggle {
                display: block;
            }
            .nav-cta {
                display: none;
            }

            #hero {
                padding: 100px 16px 60px;
            }
            .hero-title {
                font-size: clamp(2.4rem, 12vw, 3.6rem);
            }
            .hero-buttons {
                flex-direction: column;
                align-items: center;
            }
            .btn-primary,
            .btn-secondary {
                width: 100%;
                justify-content: center;
            }

            .about-cards {
                grid-template-columns: 1fr;
            }
            .about-stats {
                grid-template-columns: 1fr 1fr;
            }

            .programs-grid {
                grid-template-columns: 1fr;
            }
            .program-card {
                height: 280px;
            }

            .membership-grid {
                grid-template-columns: 1fr;
                max-width: 420px;
                margin-left: auto;
                margin-right: auto;
            }

            .coaches-grid {
                grid-template-columns: 1fr;
                max-width: 400px;
                margin-left: auto;
                margin-right: auto;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }
            .footer-bottom {
                flex-direction: column;
                gap: 12px;
                text-align: center;
            }

            .cta-content {
                flex-direction: column;
                text-align: center;
            }
            .cta-content .btn-primary {
                width: 100%;
                justify-content: center;
            }

            .modal-box {
                padding: 28px 20px 32px;
            }

            #toast {
                bottom: 16px;
                right: 16px;
                left: 16px;
                padding: 14px 20px;
            }

            section {
                padding: 60px 0;
            }
        }

        @media (max-width: 480px) {
            .about-stats {
                grid-template-columns: 1fr;
                text-align: center;
            }
            .about-stat h4 {
                font-size: 2rem;
            }
            .membership-card .price {
                font-size: 2.2rem;
            }
            .modal-box h3 {
                font-size: 1.4rem;
            }
        }
    </style>
</head>
