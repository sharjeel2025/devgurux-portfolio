            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }
        .footer-brand .brand {
            font-size: 1.8rem;
        }
        .footer-brand p {
            color: var(--text-secondary);
            font-weight: 300;
            font-size: 0.9rem;
            max-width: 320px;
            margin-top: 12px;
            line-height: 1.7;
        }
        .footer-socials {
            display: flex;
            gap: 14px;
            margin-top: 20px;
        }
        .footer-socials a {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
